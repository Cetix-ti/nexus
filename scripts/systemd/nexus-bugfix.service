[Unit]
Description=Nexus bug auto-fix worker (one-shot)
After=network.target nexus.service

[Service]
Type=oneshot
User=cetix
WorkingDirectory=/opt/nexus
EnvironmentFile=/opt/nexus/.env
ExecStart=/usr/bin/env npx tsx src/workers/bugfix-worker.ts --max=5
StandardOutput=append:/var/log/nexus-bugfix.log
StandardError=append:/var/log/nexus-bugfix.log
TimeoutStartSec=3600
