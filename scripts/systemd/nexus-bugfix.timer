[Unit]
Description=Nexus bug auto-fix — fenêtre nocturne 22h–6h
Requires=nexus-bugfix.service

[Timer]
# Lance chaque heure entre 22h et 5h (heure locale du serveur).
OnCalendar=*-*-* 22,23,00,01,02,03,04,05:00:00
RandomizedDelaySec=600
Persistent=false
Unit=nexus-bugfix.service

[Install]
WantedBy=timers.target
