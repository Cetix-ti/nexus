  startDate      DateTime       @map("start_date")
  endDate        DateTime?      @map("end_date")
  monthlyHours   Float?         @map("monthly_hours")
  hourlyRate     Float?         @map("hourly_rate")
  // Paramètres du moteur de facturation : enum "engine" (lowercase
  // "hour_bank" / "msp_monthly" / "time_and_materials" / "ftig"),
  // settings de banque d'heures (incluant hoursConsumed authoritative),
  // settings de forfait MSP, settings FTIG, billingProfileId, etc. Le
  // JSON est la source de vérité pour decideBilling(); les colonnes
