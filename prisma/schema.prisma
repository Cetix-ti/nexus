/// Saisies de temps facturables / non facturables sur les tickets.
/// Relations volontairement non déclarées en Prisma (FK SQL uniquement)
/// pour éviter d'avoir à éditer Ticket/User/Organization.
model TimeEntry {
  id              String    @id @default(cuid())
  ticketId        String    @map("ticket_id")
  organizationId  String    @map("organization_id")
  agentId         String    @map("agent_id")
  timeType        String    @map("time_type")
  startedAt       DateTime  @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationMinutes Int       @map("duration_minutes")
  description     String    @default("") @db.Text
  isAfterHours    Boolean   @default(false) @map("is_after_hours")
  isWeekend       Boolean   @default(false) @map("is_weekend")
  isUrgent        Boolean   @default(false) @map("is_urgent")
  isOnsite        Boolean   @default(false) @map("is_onsite")
  coverageStatus  String    @default("pending") @map("coverage_status")
  coverageReason  String    @default("") @map("coverage_reason")
  hourlyRate      Float?    @map("hourly_rate")
  amount          Float?
  approvalStatus  String    @default("draft") @map("approval_status")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([ticketId])
  @@index([organizationId, startedAt])
  @@index([agentId, startedAt])
  @@map("time_entries")
}

/// Clé/valeur global du tenant (branding portail, préférences, etc.).
/// Une seule ligne par clé. Ex: "portal.branding" → { logo, primaryColor }.
model TenantSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("tenant_settings")
}

// ============================================================================
// MONITORING ALERTS
// Tickets émis par des systèmes de surveillance (Zabbix, Atera, etc.).
// Le dashboard /monitoring affiche uniquement ces tickets, avec un workflow
// dédié au triage / suivi d'achat de pièces / résolution.
// ============================================================================

/// Adresses e-mail expéditrices considérées comme des systèmes de monitoring.
/// Tout ticket dont le requester (Contact) ou l'expéditeur d'origine matche
/// l'un de ces patterns est marqué `monitoringSourceId` automatiquement.
model MonitoringAlertSource {
  id             String   @id @default(cuid())
  /// Adresse e-mail OU motif (peut contenir un domaine, ex. "@zabbix.cetix.ca").
  emailOrPattern String   @unique @map("email_or_pattern")
  label          String
  /// Couleur hex utilisée pour la pastille dans le dashboard.
  color          String   @default("#3B82F6")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  alerts Ticket[] @relation("MonitoringAlertSource")

  @@map("monitoring_alert_sources")
}

/// Étapes de traitement spécifiques aux alertes monitoring (orthogonales au
/// TicketStatus standard, qui reste utilisé pour la vue ticket classique).
enum MonitoringAlertStage {
  TRIAGE // Vient d'arriver, à analyser
  INVESTIGATING // En cours d'investigation
  WAITING_PARTS // En attente d'achat / livraison de pièce
  WAITING_VENDOR // En attente d'un fournisseur tiers
  WAITING_MAINTENANCE // Planifié dans une fenêtre de maintenance
  RESOLVED // Traité
  IGNORED // Faux positif / bruit ignoré
}

// ============================================================================
// MONITORING ALERTS — parsed from email (Zabbix, Atera, FortiGate, Wazuh, etc.)
// Separate from tickets — linked via optional ticketId.
// ============================================================================

model MonitoringAlert {
  id               String  @id @default(cuid())
  organizationId   String? @map("organization_id")
  organizationName String? @map("organization_name")

  // Alert identification
  sourceType   String                  @map("source_type") // zabbix, atera, fortigate, wazuh, other
  // messageKind : distingue une vraie alerte ("ALERT") d'une notification
  // système envoyée par le RMM (commentaires sur tâches d'automatisation
  // Atera, newsletters Zabbix, etc.). Les NOTIFICATION sont masquées du
  // dashboard par défaut pour ne pas polluer la vue opérationnelle.
  messageKind  String                  @default("ALERT") @map("message_kind")
  severity     MonitoringAlertSeverity @default(WARNING)
  stage        MonitoringAlertStage    @default(TRIAGE)
  subject      String
  body         String                  @default("") @db.Text
  senderEmail  String                  @map("sender_email")
  senderDomain String                  @map("sender_domain")
  messageId    String                  @unique @map("message_id")
  receivedAt   DateTime                @map("received_at")

  // Resolution tracking
  isResolved Boolean   @default(false) @map("is_resolved")
  resolvedAt DateTime? @map("resolved_at")
  resolvedBy String?   @map("resolved_by") // userId

  // Dedup: group key identifies "same alert" across emails
  // e.g. "zabbix:host123:disk_space" — used to detect resolved alerts
  alertGroupKey String? @map("alert_group_key")

  // Linked ticket (created from this alert)
  ticketId String? @map("ticket_id")

  // Notes for Kanban workflow
  notes String? @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([organizationId, receivedAt])
  @@index([stage, receivedAt])
  @@index([sourceType])
  @@index([alertGroupKey])
  @@index([isResolved])
  @@index([messageKind, receivedAt])
  @@map("monitoring_alerts")
}

enum MonitoringAlertSeverity {
  CRITICAL
  HIGH
  WARNING
  INFO
}

// ============================================================================
// AI ASSISTANT
// Conversations, messages, memory, and category feedback.
// ============================================================================

/// Central memory shared across all agents (org knowledge, procedures, patterns)
model AiMemory {
  id        String   @id @default(cuid())
  scope     String   @default("global") // "global" or a userId for per-agent
  category  String // "client", "procedure", "pattern", "preference", etc.
  content   String   @db.Text
  source    String? // "agent:userId", "auto", "system"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([scope])
  @@index([category])
  @@map("ai_memories")
}

model AiConversation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  title     String   @default("Nouvelle conversation")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User        @relation(fields: [userId], references: [id])
  messages AiMessage[]

  @@index([userId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String   @map("conversation_id")
  role           String // "user" | "assistant" | "system"
  content        String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

model AiCategoryFeedback {
  id                String   @id @default(cuid())
  subject           String
  description       String   @default("") @db.Text
  suggestedCategory String   @map("suggested_category")
  confirmedCategory String   @map("confirmed_category")
  wasCorrect        Boolean  @map("was_correct")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("ai_category_feedback")
}

// ============================================================================
