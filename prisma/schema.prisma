// ============================================================================
// AiInvocation — journal complet des appels IA
// Une ligne par appel passant par AiOrchestrator. Sert de :
//   - audit de conformité Loi 25 (qui a accédé à quoi, via quel provider)
//   - calcul de coûts par feature / par client / par période
//   - signal d'apprentissage continu (humanAction = accept|edit|reject)
//   - source de vérité pour le droit à l'effacement (cascade sur ticketId/userId)
// Pas de FK sur ticketId/userId volontairement — on veut garder le log même
// si l'entité est supprimée, mais on supporte la cascade manuelle par script.
// ============================================================================
model AiInvocation {
  id               String    @id @default(cuid())
  feature          String // "triage" | "response_draft" | "category_suggest" | …
  taskKind         String    @map("task_kind") // sous-type (classification, generation, embedding…)
  userId           String?   @map("user_id") // qui a déclenché, null = système
  ticketId         String?   @map("ticket_id")
  organizationId   String?   @map("organization_id") // scope client
  policyJson       Json      @map("policy") // snapshot AiPolicy appliquée
  provider         String // "openai" | "ollama" | "local"
  modelName        String    @map("model_name")
  sensitivityLevel String    @map("sensitivity_level") // "public" | "internal" | "client_data" | "regulated"
  scrubApplied     Boolean   @default(false) @map("scrub_applied")
  promptHash       String    @map("prompt_hash") // SHA256 — dédup + recherche
  promptTokens     Int?      @map("prompt_tokens")
  responseTokens   Int?      @map("response_tokens")
  costCents        Int?      @map("cost_cents") // estimation
  latencyMs        Int       @map("latency_ms")
  status           String    @default("ok") // "ok" | "blocked" | "error" | "timeout"
  blockedReason    String?   @map("blocked_reason")
  response         String?   @db.Text // sortie IA (null si blocked)
  humanAction      String?   @map("human_action") // "accepted" | "edited" | "rejected" | null
  humanEdit        String?   @map("human_edit") @db.Text
  actedAt          DateTime? @map("acted_at")
  /// Version du prompt utilisé lors de l'invocation — copié depuis
  /// policy.promptVersion. Permet de grouper les invocations par version
  /// dans le dashboard (drift acceptance par version), et d'identifier une
  /// régression quand un changement de prompt fait chuter la qualité.
  promptVersion    String?   @map("prompt_version")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@index([feature, createdAt])
  @@index([organizationId, createdAt])
  @@index([ticketId])
  @@index([userId, createdAt])
  @@index([humanAction])
  @@index([feature, promptVersion])
  @@map("ai_invocations")
}

// ============================================================================
// SimilarTicketClick — feedback implicite sur le widget "Tickets similaires".
//
// Chaque fois qu'un tech clique sur un ticket proposé dans le widget, un
// ping est envoyé avec :
//   - sourceTicketId : le ticket qu'il regardait
//   - clickedTicketId : le ticket qu'il a ouvert
//   - bucket : "sameRequester" | "sameClientOpen" | "sameClientResolved" | "otherClientsResolved"
//   - semanticSim / score / matchedTokens du moment du clic
//
// Signal : un clic = la suggestion était PERTINENTE aux yeux du tech. On
// s'en sert pour :
//   1. Calculer un CTR par bucket (quel bucket est le plus utile ?)
//   2. Identifier les tokens/patterns à BOOST (ceux qui génèrent des clics)
//   3. Calibrer le seuil cross-client (si 0 clic → trop laxiste)
// ============================================================================
model SimilarTicketClick {
  id              String   @id @default(cuid())
  userId          String?  @map("user_id")
  sourceTicketId  String   @map("source_ticket_id")
  clickedTicketId String   @map("clicked_ticket_id")
  bucket          String // sameRequester | sameClientOpen | sameClientResolved | otherClientsResolved
  score           Float?
  semanticSim     Float?   @map("semantic_sim")
  matchedTokens   String[] @default([]) @map("matched_tokens")
  dwellMs         Int?     @map("dwell_ms")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([sourceTicketId, createdAt])
  @@index([bucket, createdAt])
  @@map("similar_ticket_clicks")
}

// ============================================================================
// AiAuditResult — résultat d'un audit automatique d'une invocation IA par
// un modèle plus puissant (typiquement OpenAI gpt-4o). Permet un feedback
// loop où le modèle local (gemma3:12b) est vérifié périodiquement par un
// "juge" externe, avec logs consultables et agrégats pour détecter des
// patterns d'erreurs systématiques.
//
// Flux :
//   1. Job ai-audit (toutes les 6h) sélectionne N AiInvocations récentes
//      non encore auditées (features : triage, category_suggest, etc.)
//   2. Envoie input + output à gpt-4o avec prompt "cette décision est-elle
//      correcte ?". Coût ~0.01-0.02 $ par audit.
//   3. Stocke verdict + raisonnement + suggestion d'amélioration
//   4. Admin consulte les résultats dans Paramètres > Intelligence IA.
// ============================================================================
model AiAuditResult {
  id                String   @id @default(cuid())
  invocationId      String   @unique @map("invocation_id")
  /// Feature auditée (miroir du feature de l'invocation, pour requêtes).
  feature           String
  /// "agree" | "disagree" | "partial" — verdict global du juge IA.
  verdict           String
  /// Confiance du juge dans son verdict (0.0-1.0).
  judgeConfidence   Float    @map("judge_confidence")
  /// Modèle utilisé pour auditer (ex: "gpt-4o", "gpt-4o-mini").
  judgeModel        String   @map("judge_model")
  /// Raisonnement en français — pourquoi le juge est d'accord ou non.
  reasoning         String   @db.Text
  /// Proposition concrète d'amélioration (stop-word à ajouter, seuil à
  /// changer, catégorie alternative suggérée, etc.). Null si pas d'idée.
  suggestion        String?  @db.Text
  /// Pour les triages : catégorie que le juge aurait choisi (null si
  /// d'accord avec le choix local).
  correctCategoryId String?  @map("correct_category_id")
  /// Coût de l'audit lui-même (en cents) pour monitoring budgétaire.
  auditCostCents    Int?     @map("audit_cost_cents")
  createdAt         DateTime @default(now()) @map("created_at")

  @@index([feature, createdAt])
  @@index([verdict, createdAt])
  @@map("ai_audit_results")
}

// ============================================================================
// AiPattern — agrégats calibration / signaux d'apprentissage continu.
// Pas de fine-tuning : on met à jour des poids / seuils / conventions ici,
// et l'orchestrateur les lit pour ajuster sa confiance et son retrieval.
// ============================================================================
// ============================================================================
// AI CONSENT — Loi 25 (Québec). Chaque organisation doit pouvoir contrôler
// comment l'IA traite ses données. Une absence de consent explicite permet
// quand même l'IA pour rétro-compat (existing orgs) — MAIS les nouvelles orgs
// doivent être provisionnées avec un consent explicite via l'onboarding.
//
// Granularité :
//   - aiEnabled             : master switch (bloque toutes les features IA)
//   - cloudProvidersAllowed : autorise le fallback cloud (OpenAI, Anthropic).
//                             Si false → Ollama local uniquement.
//   - learningEnabled       : autorise l'extraction de faits + pattern learning
//                             depuis les données du client.
//   - clientContentEnabled  : autorise la génération de contenu client-facing
//                             (rapport mensuel, réponse assistée, notes de
//                             résolution envoyées au client).
//
// Révocation : un admin peut passer aiEnabled=false à tout moment. Le job
// retention-purge respecte cette décision et nettoie les anciennes données
// selon le TTL standard.
// ============================================================================
model AiConsent {
  id                    String   @id @default(cuid())
  organizationId        String   @unique @map("organization_id")
  aiEnabled             Boolean  @default(true) @map("ai_enabled")
  cloudProvidersAllowed Boolean  @default(true) @map("cloud_providers_allowed")
  learningEnabled       Boolean  @default(true) @map("learning_enabled")
  clientContentEnabled  Boolean  @default(true) @map("client_content_enabled")
  /// Dernière action manuelle (admin qui a modifié les consents).
  updatedBy             String?  @map("updated_by")
  /// Notes internes (raison d'un opt-out, référence contrat, etc.).
  notes                 String?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("ai_consents")
}

model AiPattern {
  id            String    @id @default(cuid())
  scope         String // "global" | "org:xxx" | "feature:triage"
  kind          String // "acceptance_rate" | "calibration" | "convention" | …
  key           String // identifiant lisible ("category:printing" par ex.)
  value         Json // payload flexible
  sampleCount   Int       @default(0) @map("sample_count")
  confidence    Float     @default(0.5)
  /// Expiration optionnelle du pattern. Utilisé par ai-audit.ts pour les
  /// patterns auto-appliqués (≥3 occurrences → règle) : on leur pose un TTL
  /// de 90j par défaut pour forcer une re-validation périodique. Un pattern
  /// expiré ne doit PAS influencer les décisions IA — le learner devra le
  /// ré-accumuler s'il reste pertinent. null = jamais expirer (manuel,
  /// validé par un humain).
  expiresAt     DateTime? @map("expires_at")
  lastUpdatedAt DateTime  @default(now()) @updatedAt @map("last_updated_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@unique([scope, kind, key])
  @@index([scope, kind])
  @@index([expiresAt])
  @@map("ai_patterns")
}

// ============================================================================
// ASSET NOTES
// Public notes visible by portal admins + MSP agents.
// Private notes visible only by MSP agents.
// ============================================================================

model AssetNote {
  id        String   @id @default(cuid())
  assetId   String   @map("asset_id")
  authorId  String?  @map("author_id") // User (MSP agent)
  contactId String?  @map("contact_id") // Contact (portal admin)
  body      String   @db.Text
  isPrivate Boolean  @default(false) @map("is_private")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  asset   Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  author  User?    @relation(fields: [authorId], references: [id])
  contact Contact? @relation("AssetNoteContact", fields: [contactId], references: [id])

  @@index([assetId, createdAt])
  @@map("asset_notes")
}

// ============================================================================
// VEEAM BACKUP MONITORING
// Alertes de sauvegarde Veeam parsées depuis une boîte mail IMAP.
// ============================================================================

model VeeamBackupAlert {
  id               String  @id @default(cuid())
  organizationId   String? @map("organization_id")
  organizationName String? @map("organization_name")

  jobName      String         @map("job_name")
  status       VeeamJobStatus
  senderEmail  String         @map("sender_email")
  senderName   String?        @map("sender_name")
  senderDomain String         @map("sender_domain")
  subject      String
  bodySnippet  String         @default("") @map("body_snippet") @db.Text
  messageId    String         @unique @map("message_id")
  receivedAt   DateTime       @map("received_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([organizationId, receivedAt])
  @@index([status, receivedAt])
  @@index([senderDomain])
  @@map("veeam_backup_alerts")
}

enum VeeamJobStatus {
  SUCCESS
  WARNING
  FAILED
}

/// Templates de ticket générés depuis les alertes Veeam en échec. Ce sont
/// des "pré-tickets" manipulables dans le Kanban /backups colonne 1 :
/// l'utilisateur peut éditer leur titre. Quand il les déplace vers la
/// colonne 2, ils sont convertis en vrais `Ticket` (liés à la bonne org,
/// classés dans la catégorie configurée) et le template est supprimé.
///
/// Invariants :
///   - Un seul template actif par organization à la fois (unique).
///   - `refresh` remplace les templates existants sans toucher aux
///     tickets déjà convertis (colonne 2).
///   - `failedTasks` = liste distincte des `jobName` Veeam FAILED récents
///     pour cette org, stockée en JSON pour éviter une table-enfant.
model BackupTicketTemplate {
  id             String   @id @default(cuid())
  organizationId String   @unique @map("organization_id")
  /// Titre éditable par l'agent. Initialisé depuis settings.titlePattern.
  subject        String
  /// Liste des noms de jobs Veeam en échec (dédupliqués, ordonnés).
  failedTasks    String[] @map("failed_tasks")
  /// Date de l'alerte FAILED la plus récente incluse dans ce template.
  latestAlertAt  DateTime @map("latest_alert_at")
  /// Ids VeeamBackupAlert utilisés pour générer ce template — permet
  /// de détecter si de nouvelles alertes ont paru depuis.
  sourceAlertIds String[] @map("source_alert_ids")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([latestAlertAt])
  @@map("backup_ticket_templates")
}

// ===========================================================================
// Expense Reports & Entries
// ===========================================================================
model ExpenseReport {
  id           String              @id @default(cuid())
  title        String
  submitterId  String              @map("submitter_id")
  submitter    User                @relation("ExpenseReportSubmitter", fields: [submitterId], references: [id])
  status       ExpenseReportStatus @default(DRAFT)
  periodStart  DateTime?           @map("period_start")
  periodEnd    DateTime?           @map("period_end")
  totalAmount  Float               @default(0) @map("total_amount")
  notes        String?             @db.Text
  approvedById String?             @map("approved_by_id")
  approvedAt   DateTime?           @map("approved_at")
  submittedAt  DateTime?           @map("submitted_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")

  entries ExpenseEntry[]

  @@index([submitterId, status])
  @@map("expense_reports")
}

enum ExpenseReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
}

model ExpenseEntry {
  id             String        @id @default(cuid())
  reportId       String        @map("report_id")
  report         ExpenseReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  date           DateTime
  category       String
  description    String
  amount         Float
  currency       String        @default("CAD")
  vendor         String?
  receiptUrl     String?       @map("receipt_url")
  isBillable     Boolean       @default(false) @map("is_billable")
  organizationId String?       @map("organization_id")
  organization   Organization? @relation(fields: [organizationId], references: [id])
  ticketId       String?       @map("ticket_id")
  createdAt      DateTime      @default(now()) @map("created_at")

  @@index([reportId])
  @@map("expense_entries")
}

// Allocation récurrente versée par Cetix à un agent via ses dépenses
// (forfait cellulaire, forfait internet à la maison, etc.). L'agent voit
// le total dans "Mes dépenses" — le montant est additionné au mois courant
// comme référence, pas une entrée de dépense automatique.
model AgentAllowance {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String
  amountMonthly Float    @map("amount_monthly")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("agent_allowances")
}

// Configuration de facturation du déplacement pour un client :
//   - billToClient : si false, Cetix ne facture JAMAIS le déplacement à
//     ce client (contrat all-inclusive, proximité, etc.).
//   - kmRoundTrip  : distance A/R standard Cetix ↔ client, utilisée pour
//     estimer le remboursement agent (pas pour la facturation client qui
//     suit le prix fixé dans les work types).
//   - agentRatePerKm : coefficient $/km appliqué à l'agent qui s'est
//     déplacé. Cetix décide par client pour gérer les cas particuliers
//     (client lointain, tarif négocié).
// Catalogue des abonnements supplémentaires / services connexes que l'on
// vend (antivirus managé, sauvegarde Veeam, Microsoft 365 licences, etc.).
// `defaultMonthlyPrice` est le prix de référence affiché dans le catalogue ;
// chaque assignation à une org peut avoir son propre prix négocié.
model BillingAddon {
  id                  String   @id @default(cuid())
  name                String
  description         String?  @db.Text
  defaultMonthlyPrice Float    @map("default_monthly_price")
  active              Boolean  @default(true)
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  organizationAddons OrganizationAddon[]

  @@map("billing_addons")
}

// Assignation d'un addon à une organisation cliente. `monthlyPrice` peut
// être null → on reprend le defaultMonthlyPrice du catalogue ; sinon on
// utilise ce prix négocié pour cette org seulement. `quantity` permet
// de vendre N unités du même addon (ex: 12 licences M365 Business).
model OrganizationAddon {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  addonId        String       @map("addon_id")
  addon          BillingAddon @relation(fields: [addonId], references: [id], onDelete: Cascade)
  quantity       Int          @default(1)
  monthlyPrice   Float?       @map("monthly_price")
  startDate      DateTime?    @map("start_date")
  endDate        DateTime?    @map("end_date")
  notes          String?      @db.Text
  active         Boolean      @default(true)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@unique([organizationId, addonId])
  @@index([organizationId])
  @@index([addonId])
  @@map("organization_addons")
}

/// Comment un mode de prestation est couvert pour un client donné.
enum BillingCoverageMode {
  /// Facturable au taux applicable.
  BILLABLE
  /// Gratuit pour le client (saisie de temps non facturable).
  FREE
  /// Inclus au contrat (déduit de la couverture, pas facturé en plus).
  INCLUDED
}

/// Override de facturation par client (org). Tous les champs numériques
/// sont optionnels — quand non null ils remplacent le champ correspondant
/// du `BillingProfile` de base. Un seul override par org (unique).
model ClientBillingOverride {
  id                       String       @id @default(cuid())
  organizationId           String       @unique @map("organization_id")
  organization             Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// ID du BillingProfile de base (ex. "bp_standard"). Pour l'instant on
  /// stocke le slug textuel (mock-data.ts) — quand les profils seront
  /// migrés en DB, ce sera une FK.
  baseProfileId            String       @map("base_profile_id")
  isActive                 Boolean      @default(true) @map("is_active")
  effectiveFrom            DateTime     @default(now()) @map("effective_from")
  effectiveTo              DateTime?    @map("effective_to")
  // --- Couverture par mode (par client) --------------------------------
  remoteCoverage           BillingCoverageMode @default(BILLABLE) @map("remote_coverage")
  onsiteCoverage           BillingCoverageMode @default(BILLABLE) @map("onsite_coverage")
  /// Multiplicateur appliqué sur le taux pour les saisies marquées "soir".
  afterHoursMultiplier     Float        @default(1.5) @map("after_hours_multiplier")
  /// Multiplicateur appliqué sur le taux pour les saisies en weekend.
  weekendMultiplier        Float        @default(2.0) @map("weekend_multiplier")
  // --- Taux numériques (null = hérite de la base) -----------------------
  standardRate             Float?       @map("standard_rate")
  onsiteRate               Float?       @map("onsite_rate")
  remoteRate               Float?       @map("remote_rate")
  urgentRate               Float?       @map("urgent_rate")
  afterHoursRate           Float?       @map("after_hours_rate")
  weekendRate              Float?       @map("weekend_rate")
  travelRate               Float?       @map("travel_rate")
  ratePerKm                Float?       @map("rate_per_km")
  travelFlatFee            Float?       @map("travel_flat_fee")
  hourBankOverageRate      Float?       @map("hour_bank_overage_rate")
  mspExcludedRate          Float?       @map("msp_excluded_rate")
  minimumBillableMinutes   Int?         @map("minimum_billable_minutes")
  roundingIncrementMinutes Int?         @map("rounding_increment_minutes")
  notes                    String?      @db.Text
  createdAt                DateTime     @default(now()) @map("created_at")
  updatedAt                DateTime     @updatedAt @map("updated_at")

  @@map("client_billing_overrides")
}

/// Audit log d'une saisie de temps (Phase 10D).
///
/// Pour chaque action significative sur un TimeEntry (création, modif,
/// transition d'approbation, saisie au nom d'un autre, suppression), on
/// trace : qui (actorUserId), quoi (action), avant/après (JSON optionnel),
/// note libre. Particulièrement important pour les saisies au nom d'un
/// autre agent (sinon le `agentId` final ne dit pas qui a réellement
/// créé l'entrée).
model TimeEntryAuditLog {
  id           String    @id @default(cuid())
  timeEntryId  String    @map("time_entry_id")
  /// Qui a déclenché l'action. Null si l'action vient d'un système
  /// (cron, recompute, migration). On NE PAS FK vers TimeEntry car les
  /// entries peuvent être supprimées et on veut garder l'historique.
  actorUserId  String?   @map("actor_user_id")
  /// Type d'action : "create" | "update" | "transition" | "delete" |
  /// "create_on_behalf_of"
  action       String
  /// Valeurs avant l'action (JSON), null pour "create".
  fromValue    Json?     @map("from_value")
  /// Valeurs après l'action (JSON), null pour "delete".
  toValue      Json?     @map("to_value")
  /// Note libre (raison du rejet, commentaire de transition, etc.).
  note         String?   @db.Text
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([timeEntryId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("time_entry_audit_logs")
}

/// Dashboard / rapport personnalisé d'un utilisateur. Stocke la
/// configuration (widgets, métadonnées, attribution org, balises) en
/// JSON pour rester flexible face aux évolutions UI sans migration.
///
/// Avant Phase 5 : tout en localStorage du navigateur — perdu au reset,
/// non synchro entre devices, pas partageable.
model UserDashboard {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  user           User     @relation("UserDashboardOwner", fields: [userId], references: [id], onDelete: Cascade)
  /// Slug stable utilisé par l'UI pour les routes (?reportId=...) — peut
  /// venir d'un id legacy localStorage. Si null, l'id DB sert de slug.
  slug           String?
  label          String
  description    String   @default("") @db.Text
  category       String   @default("complet")
  /// `widgets`, `organizationIds`, `tags`, etc. en JSON pour ne pas
  /// figer le shape Prisma au gré des évolutions UI.
  config         Json
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([userId, slug])
  @@index([userId])
  @@map("user_dashboards")
}

/// Rapport planifié — automatise l'envoi régulier d'un livrable
/// (rapport mensuel client, pour l'instant). Le worker
/// `scheduled-reports-worker.ts` exécute tous les rapports dont
/// `nextRunAt <= now()` et met à jour `lastRunAt` / `nextRunAt` selon
/// la cadence.
///
/// Avant Phase 4 : la planification existait uniquement en localStorage,
/// aucun job ne lisait jamais ces données — la case "envoyer chaque
/// lundi" était un bouton décoratif.
model ScheduledReport {
  id              String       @id @default(cuid())
  /// Étiquette libre (ex. "Rapport mensuel HVAC — Bruno + comptabilité").
  name            String
  /// Type de rapport. Pour l'instant uniquement "monthly_report".
  kind            String       @default("monthly_report")
  organizationId  String       @map("organization_id")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// Cadence d'exécution. Valeurs supportées :
  ///   - "monthly_first_day_8am" : le 1er du mois à 8h, couvre le mois précédent
  ///   - "weekly_monday_8am" : chaque lundi à 8h, couvre la semaine précédente
  cadence         String
  /// Variante du rapport à envoyer : WITH_RATES (avec montants $) ou
  /// HOURS_ONLY (sans tarifs). BOTH = on attache les deux PDFs.
  variant         String       @default("WITH_RATES")
  /// Adresses email destinataires.
  recipients      String[]     @default([])
  isActive        Boolean      @default(true) @map("is_active")
  lastRunAt       DateTime?    @map("last_run_at")
  /// Prochaine exécution prévue. Le worker filtre sur ce champ.
  nextRunAt       DateTime?    @map("next_run_at")
  /// Compteur d'exécutions consécutives en échec — désactive la
  /// planification après N tentatives pour ne pas spammer.
  consecutiveFailures Int     @default(0) @map("consecutive_failures")
  lastErrorMessage String?    @map("last_error_message") @db.Text
  createdById     String?      @map("created_by_id")
  createdBy       User?        @relation("ScheduledReportCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  @@index([nextRunAt, isActive])
  @@index([organizationId])
  @@map("scheduled_reports")
}

/// Limite d'accès d'un user à un sous-ensemble d'organisations clients.
/// AUCUNE row pour un user = accès complet (comportement par défaut).
/// 1+ rows = restreint à ces orgs uniquement, peu importe le rôle. Le
/// SUPER_ADMIN bypass automatiquement (voir getAllowedOrgIds).
///
/// Cas d'usage : technicien dédié à un client (HVAC, par exemple) qui ne
/// doit pas voir les tickets ni le contenu des autres clients.
model UserOrganizationScope {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  user           User         @relation("UserOrgScopeUser", fields: [userId], references: [id], onDelete: Cascade)
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// READ = lecture seule sur les entités de cette org. WRITE = créer/modifier.
  permission     String       @default("WRITE")
  /// Audit trail : qui a accordé l'accès, et quand.
  grantedById    String?      @map("granted_by_id")
  grantedBy      User?        @relation("UserOrgScopeGranter", fields: [grantedById], references: [id], onDelete: SetNull)
  createdAt      DateTime     @default(now()) @map("created_at")

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
  @@map("user_organization_scopes")
}

/// Catégorie de base globale (per-tenant) : « À distance », « Sur place »,
/// etc. Le `systemTimeType` lie la catégorie à l'enum technique utilisé
/// par le moteur de facturation. Avant : stocké en localStorage global du
/// navigateur — partagé entre tous les utilisateurs d'un même device,
/// perdu au reset. Maintenant : table DB unique pour le tenant.
model BillingBaseCategory {
  id             String   @id @default(cuid())
  label          String
  systemTimeType String   @map("system_time_type")
  sortOrder      Int      @default(0) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([label])
  @@map("billing_base_categories")
}

/// Type de prestation configuré pour un client : libellé personnalisable
/// (ex. "À distance", "Sur place", "Déplacement", "Préparation"). C'est
/// l'axe "QU'EST-CE QUE FAIT L'AGENT". Le `timeType` enum lu par l'engine
/// décide la couverture (FREE/INCLUDED/BILLABLE) et la sémantique de
/// déplacement. Le tarif vient d'un `OrgRateTier` séparé.
model OrgWorkType {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label          String
  timeType       String       @map("time_type")
  isActive       Boolean      @default(true) @map("is_active")
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  timeEntries    TimeEntry[]

  @@unique([organizationId, label])
  @@index([organizationId, isActive])
  @@map("org_work_types")
}

/// Tarif horaire configuré pour un client : libellé + taux. C'est l'axe
/// "À QUEL TARIF". L'agent le choisit indépendamment du type de prestation
/// (ex. "Niveau 1 — 87$", "Niveau 3 — 95$", "Sysadmin Sr — 110$").
/// Le client peut ne définir aucun tier → l'engine retombe sur le taux
/// scalaire de `ClientBillingOverride` (standardRate / onsiteRate).
model OrgRateTier {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  label          String
  hourlyRate     Float        @map("hourly_rate")
  isActive       Boolean      @default(true) @map("is_active")
  sortOrder      Int          @default(0) @map("sort_order")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  timeEntries    TimeEntry[]

  @@unique([organizationId, label])
  @@index([organizationId, isActive])
  @@map("org_rate_tiers")
}

model OrgMileageRate {
  id             String       @id @default(cuid())
  organizationId String       @unique @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  kmRoundTrip    Float        @map("km_round_trip")
  billToClient   Boolean      @default(true) @map("bill_to_client")
  agentRatePerKm Float        @default(0.55) @map("agent_rate_per_km")
  // Forfait fixe par déplacement (en $). Si défini, remplace le calcul
  // km A/R × taux global pour la facturation au client. Null = mode
  // kilométrique classique.
  flatFee        Float?       @map("flat_fee")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("org_mileage_rates")
}

// ===========================================================================
// Purchase Orders
// ===========================================================================
model PurchaseOrder {
  id             String              @id @default(cuid())
  poNumber       String              @unique @map("po_number")
  title          String
  status         PurchaseOrderStatus @default(DRAFT)
  vendorName     String              @map("vendor_name")
  vendorContact  String?             @map("vendor_contact")
  organizationId String?             @map("organization_id")
  organization   Organization?       @relation(fields: [organizationId], references: [id])
  requestedById  String              @map("requested_by_id")
  requestedBy    User                @relation("PurchaseOrderRequester", fields: [requestedById], references: [id])
  approvedById   String?             @map("approved_by_id")
  approvedAt     DateTime?           @map("approved_at")
  subtotal       Float               @default(0)
  taxAmount      Float               @default(0) @map("tax_amount")
  totalAmount    Float               @default(0) @map("total_amount")
  currency       String              @default("CAD")
  notes          String?             @db.Text
  expectedDate   DateTime?           @map("expected_date")
  receivedDate   DateTime?           @map("received_date")
  ticketId       String?             @map("ticket_id")
  submittedAt    DateTime?           @map("submitted_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  items PurchaseOrderItem[]

  @@index([status])
  @@index([requestedById])
  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  ORDERED
  PARTIAL
  RECEIVED
  CANCELLED
}

// ===========================================================================
// Projects
// ===========================================================================
model Project {
  id                 String       @id @default(cuid())
  code               String       @unique
  name               String
  description        String?      @db.Text
  organizationId     String       @map("organization_id")
  organization       Organization @relation(fields: [organizationId], references: [id])
  type               String       @default("implementation")
  status             String       @default("draft")
  priority           String       @default("medium")
  managerId          String       @map("manager_id")
  manager            User         @relation("ProjectManager", fields: [managerId], references: [id])
  startDate          DateTime?    @map("start_date")
  targetEndDate      DateTime?    @map("target_end_date")
  actualEndDate      DateTime?    @map("actual_end_date")
  progressPercent    Int          @default(0) @map("progress_percent")
  budgetHours        Float?       @map("budget_hours")
  consumedHours      Float        @default(0) @map("consumed_hours")
  budgetAmount       Float?       @map("budget_amount")
  consumedAmount     Float        @default(0) @map("consumed_amount")
  isVisibleToClient  Boolean      @default(false) @map("is_visible_to_client")
  // Toggles granulaires (par sous-ressource) de ce que le portail client
  // expose : phases, jalons, tâches, heures, budget, membres, activité.
  // Null = valeurs par défaut (tout caché). Forme : ProjectVisibilitySettings.
  visibilitySettings Json?        @map("visibility_settings")
  tags               String[]     @default([])
  isAtRisk           Boolean      @default(false) @map("is_at_risk")
  riskNotes          String?      @map("risk_notes") @db.Text
  isArchived         Boolean      @default(false) @map("is_archived")
  // Interne (Cetix admin) vs client. Exclut des vues client /projects
  // pour apparaitre dans /internal-projects.
  isInternal         Boolean      @default(false) @map("is_internal")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  tasks                ProjectTask[]
  phases               ProjectPhase[]
  milestones           ProjectMilestone[]
  members              ProjectMember[]
  similarOut           ProjectSimilarLink[] @relation("SimilarOut")
  similarIn            ProjectSimilarLink[] @relation("SimilarIn")
  tickets              Ticket[]
  shares               SharedResource[]     @relation("SharedProject")
  // Events calendrier qui pointent vers ce projet interne.
  linkedCalendarEvents CalendarEvent[]      @relation("CalendarEventInternalProject")

  @@index([organizationId])
  @@index([status])
  @@index([isInternal])
  @@map("projects")
}

model ProjectPhase {
  id          String    @id @default(cuid())
  projectId   String    @map("project_id")
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  description String?   @db.Text
  sortOrder   Int       @default(0) @map("sort_order")
  status      String    @default("not_started")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([projectId])
  @@map("project_phases")
}

model ProjectMilestone {
  id             String    @id @default(cuid())
  projectId      String    @map("project_id")
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  description    String?   @db.Text
  targetDate     DateTime  @map("target_date")
  achievedDate   DateTime? @map("achieved_date")
  status         String    @default("upcoming")
  isCriticalPath Boolean   @default(false) @map("is_critical_path")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([projectId])
  @@map("project_milestones")
}

model ProjectMember {
  id                    String   @id @default(cuid())
  projectId             String   @map("project_id")
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId                String   @map("user_id")
  user                  User     @relation(fields: [userId], references: [id])
  role                  String   @default("contributor")
  allocatedHoursPerWeek Float?   @map("allocated_hours_per_week")
  createdAt             DateTime @default(now()) @map("created_at")

  @@unique([projectId, userId])
  @@index([projectId])
  @@map("project_members")
}

// Lien entre deux projets considérés "similaires" (contexte, scope, livrables).
// `source` indique si c'est un humain qui l'a posé ("manual") ou l'IA ("ai").
// Directionnel : A → B peut exister sans B → A (on crée les 2 sens côté UI
// uniquement quand l'utilisateur l'active explicitement).
model ProjectSimilarLink {
  id               String   @id @default(cuid())
  projectId        String   @map("project_id")
  project          Project  @relation("SimilarOut", fields: [projectId], references: [id], onDelete: Cascade)
  relatedProjectId String   @map("related_project_id")
  relatedProject   Project  @relation("SimilarIn", fields: [relatedProjectId], references: [id], onDelete: Cascade)
  source           String   @default("manual")
  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([projectId, relatedProjectId])
  @@index([projectId])
  @@map("project_similar_links")
}

// Feedback d'un humain sur une suggestion IA de projet similaire :
// "good" → la suggestion était pertinente (boost au prochain calcul).
// "bad"  → pas pertinente (filtrée des prochaines suggestions).
// Le couple (projectId, suggestedProjectId) est unique. Utilisé par l'endpoint
// /api/v1/projects/[id]/similar pour ajuster les suggestions heuristiques.
model ProjectSimilarFeedback {
  id                 String   @id @default(cuid())
  projectId          String   @map("project_id")
  suggestedProjectId String   @map("suggested_project_id")
  verdict            String // "good" | "bad"
  userId             String?  @map("user_id")
  createdAt          DateTime @default(now()) @map("created_at")

  @@unique([projectId, suggestedProjectId])
  @@index([projectId])
  @@index([suggestedProjectId])
  @@map("project_similar_feedback")
}

model ProjectTask {
  id                String    @id @default(cuid())
  projectId         String    @map("project_id")
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name              String
  description       String?   @db.Text
  status            String    @default("todo")
  priority          String    @default("medium")
  assigneeId        String?   @map("assignee_id")
  startDate         DateTime? @map("start_date")
  dueDate           DateTime? @map("due_date")
  completedAt       DateTime? @map("completed_at")
  estimatedHours    Float?    @map("estimated_hours")
  actualHours       Float?    @map("actual_hours")
  progressPercent   Int       @default(0) @map("progress_percent")
  isVisibleToClient Boolean   @default(false) @map("is_visible_to_client")
  sortOrder         Int       @default(0) @map("sort_order")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@index([projectId, status])
  @@map("project_tasks")
}

// ============================================================================
// SHARED RESOURCES — Secure sharing of projects/reports with portal orgs
// Only portal ADMIN users of the target org can see shared resources.
// Multi-tenant isolation: each share is scoped to a specific target org.
// ============================================================================

model SharedResource {
  id           String  @id @default(cuid())
  resourceType String  @map("resource_type") // "project" | "report"
  // Only one of these is set (polymorphic)
  projectId    String? @map("project_id")
  reportId     String? @map("report_id")

  // Target: which org can see this resource
  targetOrgId String       @map("target_org_id")
  targetOrg   Organization @relation("SharedWithOrg", fields: [targetOrgId], references: [id], onDelete: Cascade)

  // Access control
  portalAdminOnly Boolean @default(true) @map("portal_admin_only") // true = only admin portal users

  // Who shared it and when
  sharedByUserId String   @map("shared_by_user_id")
  sharedBy       User     @relation("SharedByUser", fields: [sharedByUserId], references: [id])
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  project Project? @relation("SharedProject", fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([resourceType, projectId, targetOrgId])
  @@unique([resourceType, reportId, targetOrgId])
  @@index([targetOrgId, resourceType])
  @@index([projectId])
  @@index([reportId])
  @@map("shared_resources")
}

model PurchaseOrderItem {
  id          String        @id @default(cuid())
  orderId     String        @map("order_id")
  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  description String
  partNumber  String?       @map("part_number")
  quantity    Int           @default(1)
  unitPrice   Float         @map("unit_price")
  totalPrice  Float         @map("total_price")
  receivedQty Int           @default(0) @map("received_qty")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([orderId])
  @@map("purchase_order_items")
}

// ============================================================================
// TICKET REMINDERS ("SNOOZE")
// ============================================================================

model TicketReminder {
  id         String    @id @default(cuid())
  ticketId   String    @map("ticket_id")
  userId     String    @map("user_id")
  remindAt   DateTime  @map("remind_at")
  note       String?   @db.Text
  notifiedAt DateTime? @map("notified_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
  @@index([remindAt, notifiedAt])
  @@map("ticket_reminders")
}

// ============================================================================
// TICKET SUBTASKS + DEPENDENCIES
// ============================================================================
// Sous-tâches : décomposition d'un ticket en étapes cochables. Pas de
// temps propre — la saisie de temps se fait au niveau du ticket parent.
// Quand toutes les sous-tâches sont cochées, le ticket peut être fermé
// sans friction.
model TicketSubtask {
  id        String    @id @default(cuid())
  ticketId  String    @map("ticket_id")
  ticket    Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  title     String
  done      Boolean   @default(false)
  doneAt    DateTime? @map("done_at")
  doneById  String?   @map("done_by_id")
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([ticketId, sortOrder])
  @@map("ticket_subtasks")
}

// Dépendance chronologique : le ticket `ticket` ne peut pas démarrer tant
// que `upstream` n'est pas terminé (status RESOLVED ou CLOSED). Contrainte
// appliquée côté UI/API (bloque le passage à IN_PROGRESS) — pas un trigger
// DB. Plusieurs upstream possibles : toutes doivent être résolues.
model TicketDependency {
  id         String   @id @default(cuid())
  ticketId   String   @map("ticket_id")
  ticket     Ticket   @relation("DependentTicket", fields: [ticketId], references: [id], onDelete: Cascade)
  upstreamId String   @map("upstream_id")
  upstream   Ticket   @relation("UpstreamTicket", fields: [upstreamId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([ticketId, upstreamId])
  @@index([upstreamId])
  @@map("ticket_dependencies")
}

// ============================================================================
// IN-APP NOTIFICATIONS
// ============================================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String // "reminder", "ticket_assigned", "ticket_updated", etc.
  title     String
  body      String?  @db.Text
  link      String? // URL to navigate to on click
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

// ============================================================================
// CALENDRIER — module multi-calendriers
// Un calendrier regroupe des événements. Plusieurs calendriers coexistent
// (renouvellements, congés, général). Les événements peuvent référencer un
// Meeting, un ticket interne, ou une org pour les renouvellements.
// ============================================================================

enum CalendarKind {
  RENEWALS // Licences, SSL, abonnements
  LEAVE // Congés, vacances, absences
  GENERAL // Calendrier général (« Localisation ») : localisation agents, rencontres, perso
  CUSTOM // Extensible
}

model Calendar {
  id          String       @id @default(cuid())
  name        String
  description String?      @db.Text
  kind        CalendarKind
  color       String       @default("#3B82F6")
  isActive    Boolean      @default(true) @map("is_active")
  /// "team" | "private" — "private" = visible uniquement au créateur
  visibility  String       @default("team")
  createdById String?      @map("created_by_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  createdBy User?           @relation(fields: [createdById], references: [id])
  events    CalendarEvent[]

  @@index([kind, isActive])
  @@map("calendars")
}

enum CalendarEventKind {
  RENEWAL // Renouvellement (licence, SSL, abonnement)
  LEAVE // Congé / absence
  WORK_LOCATION // Où travaille l'agent aujourd'hui (client, bureau, télétravail)
  MEETING // Rencontre interne (lié à Meeting)
  PERSONAL // Événement personnel (perso, rdv médical, etc.)
  OTHER
}

model CalendarEvent {
  id          String            @id @default(cuid())
  calendarId  String            @map("calendar_id")
  title       String
  description String?           @db.Text
  kind        CalendarEventKind
  startsAt    DateTime          @map("starts_at")
  endsAt      DateTime          @map("ends_at")
  allDay      Boolean           @default(false) @map("all_day")

  /// L'agent concerné (pour LEAVE, WORK_LOCATION, PERSONAL).
  ownerId        String? @map("owner_id")
  /// Emplacement texte libre : "client:HVAC", "office", "remote", "onsite:address"
  location       String?
  /// Pour RENEWAL et WORK_LOCATION chez un client. Pour un event à un
  /// seul client, `organizationId` est renseigné. Pour les events
  /// multi-clients (ex : "SF/MV SADB/BDU" visitant 2 clients le même
  /// jour), on écrit TOUS les ids dans `organizationIds` et le premier
  /// dans `organizationId` pour rétro-compat.
  organizationId  String?  @map("organization_id")
  organizationIds String[] @default([]) @map("organization_ids")
  /// Site précis chez l'organisation (facultatif).
  siteId         String? @map("site_id")

  // --- RENEWAL-specific ---
  renewalType             String? @map("renewal_type") // license | ssl | subscription | warranty
  renewalAmount           Float?  @map("renewal_amount")
  renewalNotifyDaysBefore Int?    @map("renewal_notify_days_before")
  /// Identifiant externe (vendor, numéro de commande, domaine SSL, etc.)
  renewalExternalRef      String? @map("renewal_external_ref")

  // --- LEAVE-specific ---
  leaveType     String?  @map("leave_type") // vacation | sick | personal | training
  leaveApproved Boolean? @map("leave_approved")

  // --- Récurrence simple (v1) ---
  recurrence        String? // "weekly" | "monthly" | "yearly" | null
  recurrenceEndDate DateTime? @map("recurrence_end_date")

  status String @default("active") // active | cancelled

  // --- Liens vers d'autres modules ---
  meetingId         String? @unique @map("meeting_id")
  internalTicketId  String? @map("internal_ticket_id")
  internalProjectId String? @map("internal_project_id")

  // --- Synchronisation Outlook (calendrier partagé "Localisation") ---
  // Outlook event id (immuable côté Graph) → permet d'éviter les
  // doublons lors de la synchro bidirectionnelle.
  outlookEventId    String?   @unique @map("outlook_event_id")
  /// Nom ou id du calendrier Outlook source (ex: "Localisation").
  outlookCalendarId String?   @map("outlook_calendar_id")
  /// Titre brut d'origine dans Outlook (ex: "MG/VG MRVL") — conservé
  /// même après décodage, utile pour re-tenter un match manuel.
  rawTitle          String?   @map("raw_title")
  /// "OK" | "UNDECODED" | "ERROR" | "PENDING"
  /// OK = décodé et synchronisé. UNDECODED = impossible de mapper le
  /// titre (agents/client inconnus). ERROR = sync Graph a échoué.
  syncStatus        String?   @map("sync_status")
  syncError         String?   @map("sync_error")
  /// Dernière synchro Graph → Nexus (pour ignorer les updates anciens).
  lastSyncedAt      DateTime? @map("last_synced_at")
  /// Hash de dernière version vue pour éviter d'écraser une édition
  /// Nexus plus récente avec un import Outlook obsolète.
  outlookEtag       String?   @map("outlook_etag")

  createdById String?  @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  /// Soft-delete : rempli quand l'event est supprimé dans Outlook mais
  /// qu'on conserve la trace côté Nexus (tickets liés, time-entries, etc.).
  /// L'UI filtre ces rows par défaut mais peut les afficher grisés.
  deletedAt DateTime? @map("deleted_at")

  calendar        Calendar      @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  owner           User?         @relation("CalendarEventOwner", fields: [ownerId], references: [id])
  createdBy       User?         @relation("CalendarEventCreator", fields: [createdById], references: [id])
  organization    Organization? @relation(fields: [organizationId], references: [id])
  site            Site?         @relation(fields: [siteId], references: [id])
  // Si le Meeting est supprimé, on supprime aussi son CalendarEvent
  // (évite un event kind=MEETING orphelin pointant vers un meeting inexistant).
  // Et symétriquement : si l'event est supprimé, le Meeting aussi (sinon
  // un Meeting orphelin sans trace dans le calendrier).
  meeting         Meeting?      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  // Liens vers tickets/projets internes (suivi visuel dans le calendrier).
  // SetNull → si la ressource liée est supprimée, l'event reste mais perd son lien.
  internalTicket  Ticket?       @relation("CalendarEventInternalTicket", fields: [internalTicketId], references: [id], onDelete: SetNull)
  internalProject Project?      @relation("CalendarEventInternalProject", fields: [internalProjectId], references: [id], onDelete: SetNull)
  // Tickets planifiés sur cet événement (WORK_LOCATION : visite client).
  // SetNull côté Ticket → si l'event est supprimé, les tickets liés gardent
  // leur vie propre (juste délié).
  linkedTickets   Ticket[]      @relation("CalendarEventLinkedTickets")

  /// Multi-agent : ownerId seul limite à une personne — pour "MG/VG MRVL"
  /// qui désigne 2 agents, on passe par cette table de jointure.
  /// Le ownerId reste pour backward-compat (premier agent).
  agents CalendarEventAgent[]

  @@index([calendarId, startsAt])
  @@index([ownerId, startsAt])
  @@index([kind, startsAt])
  @@index([internalTicketId])
  @@index([internalProjectId])
  @@index([outlookEventId])
  @@map("calendar_events")
}

/// Jointure événement calendrier ↔ agent (pour les WORK_LOCATION
/// multi-agents typiquement). Cascade au delete d'event. On peut
/// encore lire un agent unique via event.ownerId mais ce n'est plus
/// obligatoire.
model CalendarEventAgent {
  eventId String @map("event_id")
  userId  String @map("user_id")

  event CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation("CalendarEventAgentUser", fields: [userId], references: [id], onDelete: Cascade)

  @@id([eventId, userId])
  @@index([userId])
  @@map("calendar_event_agents")
}

// ============================================================================
// RENCONTRES INTERNES — Meeting + agenda + notes + participants
// ============================================================================

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  startsAt    DateTime @map("starts_at")
  endsAt      DateTime @map("ends_at")
  location    String? // "Bureau Cetix", "Teams", "Zoom URL", etc.

  /// Notes de réunion — HTML rich text. Alimenté en direct pendant la
  /// rencontre. Source de l'analyse IA pour suggérer des tickets.
  notes          String?   @db.Text
  notesUpdatedAt DateTime? @map("notes_updated_at")

  status String @default("scheduled") // scheduled | in_progress | completed | cancelled

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  createdBy        User                 @relation("MeetingCreator", fields: [createdById], references: [id])
  calendarEvent    CalendarEvent?
  agenda           MeetingAgendaItem[]
  participants     MeetingParticipant[]
  /// Tickets internes générés depuis cette rencontre (via suggestion IA
  /// ou création manuelle depuis la fiche réunion).
  generatedTickets Ticket[]

  @@index([startsAt])
  @@index([status])
  @@map("meetings")
}

model MeetingAgendaItem {
  id              String   @id @default(cuid())
  meetingId       String   @map("meeting_id")
  title           String
  description     String?  @db.Text
  addedById       String   @map("added_by_id")
  order           Int      @default(0)
  status          String   @default("pending") // pending | in_progress | done | deferred
  notes           String?  @db.Text
  durationMinutes Int?     @map("duration_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  addedBy User    @relation(fields: [addedById], references: [id])

  @@index([meetingId, order])
  @@map("meeting_agenda_items")
}

model MeetingParticipant {
  id        String   @id @default(cuid())
  meetingId String   @map("meeting_id")
  userId    String   @map("user_id")
  /// "organizer" | "attendee" | "optional"
  role      String   @default("attendee")
  attended  Boolean?
  createdAt DateTime @default(now()) @map("created_at")

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([meetingId, userId])
  @@index([userId])
  @@map("meeting_participants")
}

// ============================================================================
// SECURITY CENTER — vue 360 des alertes de sécurité (AD, Wazuh, Bitdefender…)
//
// Modèle à deux niveaux :
//   - SecurityAlert     : un événement brut (un courriel, une réponse API)
//   - SecurityIncident  : groupement logique de plusieurs alertes similaires,
//                         unique par `correlationKey`. C'est l'objet affiché
//                         dans l'UI et éventuellement converti en ticket.
//
// La corrélation suit des règles simples :
//   - AD Account Lockout   → org + userPrincipal
//   - Inactive Account     → org + userPrincipal
//   - Persistence (Wazuh)  → org + endpoint + software
//   - CVE (Wazuh)          → org + endpoint + cveId
//   - Bitdefender malware  → org + endpoint + threatName
//
// Extensible : tout nouveau décodeur produit une `SecurityAlert` avec une
// `correlationKey` stable, et le corrélateur s'occupe de l'incident.
// ============================================================================

model SecurityAlert {
  id             String   @id @default(cuid())
  source         String // "ad_email" | "wazuh_email" | "bitdefender_api" | ...
  kind           String // "account_lockout" | "inactive_account" | "persistence_tool" | "cve" | "malware" | ...
  severity       String? // "critical" | "high" | "warning" | "info"
  externalId     String?  @map("external_id") // dedup key (messageId ou id API)
  organizationId String?  @map("organization_id")
  endpoint       String?
  userPrincipal  String?  @map("user_principal")
  title          String
  summary        String?  @db.Text
  rawPayload     Json?    @map("raw_payload") @db.JsonB
  receivedAt     DateTime @default(now()) @map("received_at")
  correlationKey String   @map("correlation_key")
  incidentId     String?  @map("incident_id")
  /// True quand le corps de l'alerte matche un mot-clé "downgrade"
  /// configuré par l'admin (ex: "fortigate"). Ces alertes vont dans
  /// une section "moins importantes" de l'UI.
  isLowPriority  Boolean  @default(false) @map("is_low_priority")

  organization Organization?     @relation(fields: [organizationId], references: [id])
  incident     SecurityIncident? @relation(fields: [incidentId], references: [id], onDelete: SetNull)

  @@unique([source, externalId])
  @@index([source, kind, receivedAt])
  @@index([correlationKey])
  @@index([organizationId, receivedAt])
  /// Critique : sans cet index le nested-include Prisma "5 dernières alertes
  /// par incident" force un Seq Scan sur des millions de rows. Créé manuellement
  /// en prod via CREATE INDEX CONCURRENTLY, reflété ici pour cohérence schema.
  @@index([incidentId, receivedAt(sort: Desc)])
  @@map("security_alerts")
}

model SecurityIncident {
  id              String   @id @default(cuid())
  source          String
  kind            String
  severity        String?
  organizationId  String?  @map("organization_id")
  endpoint        String?
  userPrincipal   String?  @map("user_principal")
  software        String?
  cveId           String?  @map("cve_id")
  title           String
  summary         String?  @db.Text
  status          String   @default("open") // open | investigating | waiting_client | resolved | closed
  assigneeId      String?  @map("assignee_id")
  // 1 ticket → N incidents (ex: ticket endpoint qui regroupe CVE +
  // persistence + comportements suspects d'un même poste). Pas de @unique
  // pour autoriser ce mode d'agrégation.
  ticketId        String?  @map("ticket_id")
  correlationKey  String   @unique @map("correlation_key")
  occurrenceCount Int      @default(1) @map("occurrence_count")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")
  metadata        Json?    @db.JsonB
  /// Miroir du flag sur SecurityAlert : une fois qu'une alerte low
  /// priority est ingérée, l'incident hérite du flag pour que l'UI
  /// puisse filtrer sans rejoindre la table alerts.
  isLowPriority   Boolean  @default(false) @map("is_low_priority")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization?   @relation(fields: [organizationId], references: [id])
  assignee     User?           @relation("SecurityIncidentAssignee", fields: [assigneeId], references: [id])
  ticket       Ticket?         @relation("SecurityIncidentTicket", fields: [ticketId], references: [id])
  alerts       SecurityAlert[]

  @@index([source, kind, status])
  @@index([organizationId, status])
  @@index([assigneeId])
  @@index([lastSeenAt])
  @@map("security_incidents")
}

// ============================================================================
// PERSISTENCE SOFTWARE WHITELIST — règles métier pour les logiciels de
// télé-assistance (AnyDesk, TeamViewer, Splashtop, etc.) détectés par
// Wazuh syscollector. Cascade en 3 niveaux :
//
//   1. HOST-level     : ce logiciel est autorisé sur CE poste (override le plus fort)
//   2. CLIENT-level   : ce logiciel est autorisé pour tous les postes de CETTE org
//   3. DEFAULT-level  : ce logiciel est autorisé pour TOUS les clients (global MSP)
//
// Le résolveur retourne la PREMIÈRE règle matchante en descendant la
// cascade. Règle non trouvée = logiciel NON AUTORISÉ → alerte HIGH/CRITICAL.
// ============================================================================

model SecurityPersistenceWhitelist {
  id             String   @id @default(cuid())
  scope          String // "host" | "client" | "default"
  organizationId String?  @map("organization_id") // requis si scope=client OU host
  hostname       String? // requis si scope=host (ex: "MV-LAP-33", sans préfixe client)
  softwareName   String   @map("software_name") // normalisé (TeamViewer, AnyDesk, …)
  allowed        Boolean  @default(true) // false = explicite "jamais autorisé"
  notes          String?
  createdBy      String?  @map("created_by") // User.id qui a ajouté
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([scope, softwareName])
  @@index([organizationId, scope])
  @@index([hostname])
  @@map("security_persistence_whitelists")
}

// ============================================================================
// SECURITY NOTIFICATION TEMPLATES — HTML + destinataires configurables par
// kind d'alerte. Substitution de placeholders {{hostname}} {{severity}} etc.
// au moment de l'envoi. Un template par kind (persistence_tool, cve, etc.).
// ============================================================================

model SecurityNotificationTemplate {
  id         String   @id @default(cuid())
  kind       String   @unique // "persistence_tool" | "cve" | "malware" | ...
  enabled    Boolean  @default(true)
  recipients String[] // liste d'adresses email
  subject    String // template avec placeholders
  htmlBody   String   @map("html_body") @db.Text
  textBody   String?  @map("text_body") @db.Text
  updatedAt  DateTime @updatedAt @map("updated_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("security_notification_templates")
}

// ============================================================================
// MONTHLY CLIENT REPORT — rapport mensuel PDF par client
//
// Livrable contractuel (pas un rapport analytique interactif). Un rapport par
// (organization, period) maximum. `payloadJson` contient le snapshot figé des
// données calculées au moment de la génération — source de vérité ; le PDF
// peut être regénéré à partir de ce payload sans recalcul DB (utile si on
// change le template). `filePath` relatif pour permettre migration S3 future.
// ============================================================================

model MonthlyClientReport {
  id                String   @id @default(cuid())
  organizationId    String   @map("organization_id")
  /// Premier jour du mois couvert (ex: 2026-04-01 pour avril 2026).
  period            DateTime @db.Date
  generatedAt       DateTime @default(now()) @map("generated_at")
  generatedByUserId String?  @map("generated_by_user_id")

  /// Chemin relatif à la racine de stockage (ex: "acme/2026-04/ck2....pdf").
  /// Null tant que le PDF n'a pas encore été rendu (payload existe avant).
  filePath      String? @map("file_path")
  fileSizeBytes Int?    @map("file_size_bytes")
  /// sha256 du fichier PDF — détection corruption + intégrité archivage.
  sha256        String?

  /// Snapshot complet des données du rapport au moment de la génération.
  /// Contient : organisation, période, sections heures, tickets, demandeurs,
  /// déplacements, totaux. Regénérable en PDF sans recalcul.
  payloadJson Json @map("payload_json")

  publishedToPortal Boolean   @default(false) @map("published_to_portal")
  publishedAt       DateTime? @map("published_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  generatedByUser User?        @relation("MonthlyReportGenerator", fields: [generatedByUserId], references: [id], onDelete: SetNull)

  @@unique([organizationId, period])
  @@index([organizationId, period(sort: Desc)])
  @@map("monthly_client_reports")
}

// ============================================================================
// INFRASTRUCTURE RÉSEAU (liens Internet, IPs publiques, VLANs)
// ============================================================================
// Un "lien Internet" = une connexion souscrite auprès d'un ISP pour un
// client (optionnellement rattachée à un site/bâtiment). Un lien peut
// avoir 0..N blocs d'IP publiques (IP unique, plage, subnet), ou aucun
// si l'ISP fournit uniquement une IP dynamique/CGNAT/NAT.

model OrgInternetLink {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // null = lien non rattaché à un site précis (ex: lien partagé multi-sites)
  siteId         String?  @map("site_id")
  site           Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  isp            String   // nom du fournisseur (Bell, Vidéotron, TELUS, Cogeco, …)
  label          String?  // étiquette libre (« Lien principal », « Backup fibre »…)
  downloadMbps   Int?     @map("download_mbps")
  uploadMbps     Int?     @map("upload_mbps")
  gateway        String?
  dnsPrimary     String?  @map("dns_primary")
  dnsSecondary   String?  @map("dns_secondary")
  notes          String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  ipBlocks       OrgIpBlock[]

  @@index([organizationId])
  @@index([siteId])
  @@map("org_internet_links")
}

model OrgIpBlock {
  id        String      @id @default(cuid())
  linkId    String      @map("link_id")
  link      OrgInternetLink @relation(fields: [linkId], references: [id], onDelete: Cascade)
  kind      IpBlockKind
  // Représentation textuelle canonique :
  //   SINGLE → "203.0.113.45"
  //   RANGE  → "203.0.113.40-203.0.113.45"
  //   SUBNET → "203.0.113.0/29"
  value     String
  label     String?     // usage libre (« NAT firewall », « VPN site-à-site »…)
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([linkId])
  @@map("org_ip_blocks")
}

enum IpBlockKind {
  SINGLE
  RANGE
  SUBNET
}

model SiteVlan {
  id           String   @id @default(cuid())
  siteId       String   @map("site_id")
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  vlanId       Int      @map("vlan_id")
  name         String
  dhcpServer   String?  @map("dhcp_server")
  dnsPrimary   String?  @map("dns_primary")
  dnsSecondary String?  @map("dns_secondary")
  description  String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([siteId])
  @@map("site_vlans")
}

// ============================================================================
// SOCLE CONTENT — visibilité, sync template↔instance, relations cross-modules
// Partagé par Particularités, Politiques, Logiciels, Changements, Documents.
// ============================================================================

/// Niveau d'exposition d'un contenu. Toujours explicite, jamais implicite.
enum ContentVisibility {
  INTERNAL     // agents uniquement (défaut sécuritaire)
  CLIENT_ADMIN // + portail client, rôle admin de l'org
  CLIENT_ALL   // + portail client, tout rôle (rare, opt-in explicite)
}

/// État de synchronisation entre une instance client et son template global.
enum ContentSyncState {
  IN_SYNC  // aligné avec la version courante du template
  DRIFTED  // le template a évolué depuis l'instanciation → révision nécessaire
  DETACHED // lien rompu volontairement, édition libre côté client
}

/// Statut de cycle de vie d'un contenu.
enum ContentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

/// Capacités techniques déclarées d'une organisation. Source de vérité pour
/// l'affichage conditionnel des sections (GPO masqué si !hasAD, etc.).
/// 1:1 avec Organization. `extras` permet d'ajouter des flags ponctuels sans
/// migration.
model OrgCapabilities {
  id                String   @id @default(cuid())
  organizationId    String   @unique @map("organization_id")
  hasAD             Boolean  @default(false) @map("has_ad")
  hasAzureAD        Boolean  @default(false) @map("has_azure_ad")
  hasEntra          Boolean  @default(false) @map("has_entra")
  hasM365           Boolean  @default(false) @map("has_m365")
  hasExchangeOnPrem Boolean  @default(false) @map("has_exchange_onprem")
  hasVPN            Boolean  @default(false) @map("has_vpn")
  hasRDS            Boolean  @default(false) @map("has_rds")
  hasHyperV         Boolean  @default(false) @map("has_hyperv")
  hasVMware         Boolean  @default(false) @map("has_vmware")
  hasOnPremServers  Boolean  @default(false) @map("has_onprem_servers")
  hasBackupsVeeam   Boolean  @default(false) @map("has_backups_veeam")
  hasSOC            Boolean  @default(false) @map("has_soc")
  hasMDM            Boolean  @default(false) @map("has_mdm")
  hasKeePass        Boolean  @default(false) @map("has_keepass")
  /// Permet l'interface anglaise sur les postes/logiciels corporatifs pour
  /// cette org. Peut être surchargé par logiciel (SoftwareInstance.allowEnglishUI).
  allowEnglishUI    Boolean  @default(true) @map("allow_english_ui")
  /// Mois de début d'année fiscale (1-12). Défaut 1 = janvier. Utilisé par le
  /// module Budgets pour déterminer la période d'un budget annuel.
  fiscalYearStartMonth Int  @default(1) @map("fiscal_year_start_month")
  extras            Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  updatedByUserId   String?  @map("updated_by_user_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedBy    User?        @relation("OrgCapabilitiesUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@map("org_capabilities")
}

/// Relation polymorphique (string-typed, pas de FK) entre objets Nexus. Permet
/// de lier particularités ↔ actifs ↔ politiques ↔ logiciels ↔ changements sans
/// exploser le schéma. Les types valides sont documentés dans
/// src/lib/content/relations.ts (ex: "particularity", "asset", "software",
/// "policy", "change", "ticket", "contract").
model ContentRelation {
  id              String   @id @default(cuid())
  sourceType      String   @map("source_type")
  sourceId        String   @map("source_id")
  targetType      String   @map("target_type")
  targetId        String   @map("target_id")
  relationType    String   @default("related") @map("relation_type")
  note            String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")
  createdByUserId String?  @map("created_by_user_id")

  createdBy User? @relation("ContentRelationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@unique([sourceType, sourceId, targetType, targetId, relationType])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@map("content_relations")
}

// ============================================================================
// PARTICULARITÉS — connaissances opérationnelles spécifiques à un client
// ============================================================================

/// Catégorie large et stable (Infrastructure, Logiciels, Utilisateurs, …).
/// Seedée par scripts/seed-particularity-categories.ts. Partagée entre tous
/// les clients. Ajout libre par MSP_ADMIN.
model ParticularityCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String   @default("📌")
  color       String   @default("#3B82F6")
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isSystem    Boolean  @default(false) @map("is_system") // seedé → non supprimable
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  templates       ParticularityTemplate[]
  particularities Particularity[]

  @@map("particularity_categories")
}

/// Template réutilisable — contenu maître qu'on peut appliquer à N clients.
/// Les instances dérivées pointent sur le template via templateId et leur
/// syncState reflète l'alignement.
model ParticularityTemplate {
  id                   String            @id @default(cuid())
  title                String
  categoryId           String?           @map("category_id")
  summary              String?           @db.Text
  body                 String            @default("") @db.Text // TipTap HTML
  tags                 String[]          @default([])
  /// [{ key, label, required, hint, default }] — variables à résoudre
  /// lors de l'application à un client.
  variables            Json?
  /// Clés OrgCapabilities requises pour appliquer ce template (filtre
  /// dans ApplyToOrgsModal).
  requiresCapabilities String[]          @default([]) @map("requires_capabilities")
  visibilityDefault    ContentVisibility @default(INTERNAL) @map("visibility_default")
  version              Int               @default(1)
  publishedAt          DateTime?         @map("published_at")
  archivedAt           DateTime?         @map("archived_at")
  createdByUserId      String?           @map("created_by_user_id")
  updatedByUserId      String?           @map("updated_by_user_id")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  category  ParticularityCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?                  @relation("ParticularityTemplateCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?                  @relation("ParticularityTemplateUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  instances Particularity[]

  @@index([categoryId])
  @@index([archivedAt])
  @@map("particularity_templates")
}

/// Particularité appliquée à une organisation. Autonome (templateId=null) ou
/// dérivée d'un ParticularityTemplate.
model Particularity {
  id                  String            @id @default(cuid())
  organizationId      String            @map("organization_id")
  templateId          String?           @map("template_id")
  /// Version du template au moment du lien (permet de détecter DRIFTED).
  templateVersion     Int?              @map("template_version")
  title               String
  categoryId          String?           @map("category_id")
  summary             String?           @db.Text
  body                String            @default("") @db.Text // TipTap HTML
  tags                String[]          @default([])
  resolvedVariables   Json?             @map("resolved_variables")
  visibility          ContentVisibility @default(INTERNAL)
  status              ContentStatus     @default(ACTIVE)
  syncState           ContentSyncState  @default(IN_SYNC) @map("sync_state")
  version             Int               @default(1)
  authorId            String?           @map("author_id")
  updatedByUserId     String?           @map("updated_by_user_id")
  lastReviewedAt      DateTime?         @map("last_reviewed_at")
  /// True si la catégorie a été suggérée par l'IA sans correction humaine.
  /// Sert au feedback loop (memory `category_autoapply`).
  aiCategorySuggested Boolean           @default(false) @map("ai_category_suggested")
  /// Full-text search — tsvector populé par trigger (config french_unaccent).
  searchVector        Unsupported("tsvector")? @map("search_vector")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  organization Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     ParticularityTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  category     ParticularityCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author       User?                  @relation("ParticularityAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  updatedBy    User?                  @relation("ParticularityUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  versions     ParticularityVersion[]

  @@index([organizationId])
  @@index([categoryId])
  @@index([templateId])
  @@index([visibility])
  @@index([status])
  @@index([syncState])
  @@index([searchVector], type: Gin)
  @@map("particularities")
}

/// Snapshot immuable d'une particularité — historique + rollback.
model ParticularityVersion {
  id              String   @id @default(cuid())
  particularityId String   @map("particularity_id")
  version         Int
  /// Snapshot complet : title, body, summary, categoryId, tags, visibility,
  /// resolvedVariables. Regénérable par restore.
  snapshot        Json
  changeNote      String?  @db.Text @map("change_note")
  authorId        String?  @map("author_id")
  createdAt       DateTime @default(now()) @map("created_at")

  particularity Particularity @relation(fields: [particularityId], references: [id], onDelete: Cascade)
  author        User?         @relation("ParticularityVersionAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([particularityId, version])
  @@index([particularityId, version(sort: Desc)])
  @@map("particularity_versions")
}

// ============================================================================
// LOGICIELS — catalogue global + déclinaison par client, installeurs, licences
// ============================================================================

/// Catégorie large de logiciel (Métier, Bureautique, Sécurité, …). Seedée.
model SoftwareCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String   @default("📦")
  color       String   @default("#8B5CF6")
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  templates SoftwareTemplate[]
  instances SoftwareInstance[]

  @@map("software_categories")
}

/// Fiche logiciel dans la bibliothèque MSP. Peut être déclinée par client.
model SoftwareTemplate {
  id                   String            @id @default(cuid())
  name                 String
  vendor               String?
  categoryId           String?           @map("category_id")
  version              String?
  /// Documentation générale du logiciel (HTML riche).
  body                 String            @default("") @db.Text
  /// [{ label, url }]
  links                Json?
  /// { supportEmail, supportPhone, supportUrl, notes }
  supportInfo          Json?             @map("support_info")
  requiresCapabilities String[]          @default([]) @map("requires_capabilities")
  visibilityDefault    ContentVisibility @default(INTERNAL) @map("visibility_default")
  tags                 String[]          @default([])
  schemaVersion        Int               @default(1) @map("schema_version")
  publishedAt          DateTime?         @map("published_at")
  archivedAt           DateTime?         @map("archived_at")
  createdByUserId      String?           @map("created_by_user_id")
  updatedByUserId      String?           @map("updated_by_user_id")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  category   SoftwareCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy  User?             @relation("SoftwareTemplateCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy  User?             @relation("SoftwareTemplateUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  instances  SoftwareInstance[]
  installers SoftwareInstaller[] @relation("SoftwareTemplateInstaller")
  licenses   SoftwareLicense[]   @relation("SoftwareTemplateLicense")
  procedures SoftwareProcedure[] @relation("SoftwareTemplateProcedure")

  @@index([categoryId])
  @@index([archivedAt])
  @@map("software_templates")
}

/// Logiciel déployé/autorisé chez un client. Peut être natif (pas de template)
/// ou dérivé.
model SoftwareInstance {
  id                         String            @id @default(cuid())
  organizationId             String            @map("organization_id")
  templateId                 String?           @map("template_id")
  templateSchemaVersion      Int?              @map("template_schema_version")
  name                       String
  vendor                     String?
  categoryId                 String?           @map("category_id")
  version                    String?
  /// Override de la doc globale pour ce client (HTML, vide = hérite template).
  bodyOverride               String?           @db.Text @map("body_override")
  links                      Json?
  supportInfo                Json?             @map("support_info")
  tags                       String[]          @default([])
  visibility                 ContentVisibility @default(INTERNAL)
  status                     ContentStatus     @default(ACTIVE)
  syncState                  ContentSyncState  @default(IN_SYNC) @map("sync_state")
  /// Contact client responsable de la gestion (accès, demandes).
  responsibleClientContactId String?           @map("responsible_client_contact_id")
  /// User Cetix responsable de l'administration.
  responsibleCetixUserId     String?           @map("responsible_cetix_user_id")
  /// Override de la capacité org `allowEnglishUI` pour ce logiciel précis.
  /// null = hérite org.
  allowEnglishUI             Boolean?          @map("allow_english_ui")
  updatedByUserId            String?           @map("updated_by_user_id")
  searchVector               Unsupported("tsvector")? @map("search_vector")
  createdAt                  DateTime          @default(now()) @map("created_at")
  updatedAt                  DateTime          @updatedAt @map("updated_at")

  organization              Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template                  SoftwareTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  category                  SoftwareCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  responsibleClientContact  Contact?           @relation("SoftwareInstanceClientOwner", fields: [responsibleClientContactId], references: [id], onDelete: SetNull)
  responsibleCetixUser      User?              @relation("SoftwareInstanceCetixOwner", fields: [responsibleCetixUserId], references: [id], onDelete: SetNull)
  updatedBy                 User?              @relation("SoftwareInstanceUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  installers                SoftwareInstaller[] @relation("SoftwareInstanceInstaller")
  licenses                  SoftwareLicense[]   @relation("SoftwareInstanceLicense")
  procedures                SoftwareProcedure[] @relation("SoftwareInstanceProcedure")
  contactAccesses           ContactSoftwareAccess[]

  @@index([organizationId])
  @@index([templateId])
  @@index([categoryId])
  @@index([searchVector], type: Gin)
  @@index([visibility])
  @@index([status])
  @@map("software_instances")
}

enum SoftwareInstallerScope {
  GLOBAL // rattaché à un SoftwareTemplate, commun à tous les clients
  ORG    // rattaché à un SoftwareInstance, spécifique à un client
}

/// Fichier d'installation stocké. Peut être global (catalogue MSP) ou
/// spécifique à un client. Un token SoftwareDownloadLink permet de partager
/// l'URL externe vers nexus.cetix.ca/d/<token>.
model SoftwareInstaller {
  id                  String                 @id @default(cuid())
  title               String
  filename            String
  sizeBytes           Int                    @map("size_bytes")
  sha256              String
  /// Chemin relatif à la racine de stockage (ex : "software/<templateId>/<cuid>.msi")
  storagePath         String                 @map("storage_path")
  scope               SoftwareInstallerScope
  softwareTemplateId  String?                @map("software_template_id")
  softwareInstanceId  String?                @map("software_instance_id")
  organizationId      String?                @map("organization_id")
  notes               String?
  uploadedByUserId    String?                @map("uploaded_by_user_id")
  createdAt           DateTime               @default(now()) @map("created_at")

  template     SoftwareTemplate?     @relation("SoftwareTemplateInstaller", fields: [softwareTemplateId], references: [id], onDelete: Cascade)
  instance     SoftwareInstance?     @relation("SoftwareInstanceInstaller", fields: [softwareInstanceId], references: [id], onDelete: Cascade)
  organization Organization?         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User?                 @relation("SoftwareInstallerUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  downloadLinks SoftwareDownloadLink[]

  @@index([softwareTemplateId])
  @@index([softwareInstanceId])
  @@index([organizationId])
  @@map("software_installers")
}

/// Lien public signé pour télécharger un installeur depuis l'externe. Token
/// non-devinable, expiration obligatoire, quota max, PIN optionnel, audit.
model SoftwareDownloadLink {
  id              String   @id @default(cuid())
  installerId     String   @map("installer_id")
  organizationId  String?  @map("organization_id")
  /// Token base64url (32 bytes). Unique, indexé.
  token           String   @unique
  label           String?
  expiresAt       DateTime @map("expires_at")
  maxDownloads    Int?     @map("max_downloads")
  downloadCount   Int      @default(0) @map("download_count")
  requirePin      Boolean  @default(false) @map("require_pin")
  pinHash         String?  @map("pin_hash")
  lastUsedAt      DateTime? @map("last_used_at")
  lastUsedIp      String?   @map("last_used_ip")
  revokedAt       DateTime? @map("revoked_at")
  createdByUserId String?  @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  installer    SoftwareInstaller      @relation(fields: [installerId], references: [id], onDelete: Cascade)
  organization Organization?          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?                  @relation("SoftwareDownloadLinkCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  audits       SoftwareDownloadAudit[]

  @@index([installerId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("software_download_links")
}

model SoftwareDownloadAudit {
  id           String   @id @default(cuid())
  linkId       String   @map("link_id")
  downloadedAt DateTime @default(now()) @map("downloaded_at")
  ip           String?
  userAgent    String?  @map("user_agent")
  success      Boolean  @default(true)
  failureReason String? @map("failure_reason")

  link SoftwareDownloadLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, downloadedAt(sort: Desc)])
  @@map("software_download_audits")
}

enum SoftwareLicenseScope {
  GLOBAL_POOL // pool MSP (licences revendues à N clients)
  ORG         // licence site attribuée à un client
  PER_SEAT    // licence rattachée à un Asset
  PER_USER    // licence rattachée à un Contact
}

/// Licence logiciel. scope détermine les liens (template, instance, org,
/// contact, asset). licenseKey est stocké chiffré (service applicatif).
model SoftwareLicense {
  id                 String               @id @default(cuid())
  scope              SoftwareLicenseScope
  softwareTemplateId String?              @map("software_template_id")
  softwareInstanceId String?              @map("software_instance_id")
  organizationId     String?              @map("organization_id")
  contactId          String?              @map("contact_id")
  assetId            String?              @map("asset_id")
  contractId         String?              @map("contract_id")
  /// Clé/identifiant de licence. Stocké chiffré (voir src/lib/security/crypto.ts
  /// une fois implémenté — pour l'instant en clair, TODO chiffrement at-rest).
  licenseKey         String?              @db.Text @map("license_key")
  seats              Int?
  usedSeats          Int?                 @map("used_seats")
  startDate          DateTime?            @map("start_date")
  endDate            DateTime?            @map("end_date")
  notes              String?              @db.Text
  visibility         ContentVisibility    @default(INTERNAL)
  createdByUserId    String?              @map("created_by_user_id")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  template     SoftwareTemplate? @relation("SoftwareTemplateLicense", fields: [softwareTemplateId], references: [id], onDelete: Cascade)
  instance     SoftwareInstance? @relation("SoftwareInstanceLicense", fields: [softwareInstanceId], references: [id], onDelete: Cascade)
  organization Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contact      Contact?          @relation("SoftwareLicenseContact", fields: [contactId], references: [id], onDelete: SetNull)
  asset        Asset?            @relation("SoftwareLicenseAsset", fields: [assetId], references: [id], onDelete: SetNull)
  contract     Contract?         @relation("SoftwareLicenseContract", fields: [contractId], references: [id], onDelete: SetNull)
  createdBy    User?             @relation("SoftwareLicenseCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([softwareTemplateId])
  @@index([softwareInstanceId])
  @@index([organizationId])
  @@index([endDate])
  @@index([scope])
  @@map("software_licenses")
}

enum SoftwareProcedureKind {
  INSTALL
  CONFIG
  UNINSTALL
  TROUBLESHOOT
  UPGRADE
  OTHER
}

/// Procédure attachée à un logiciel. Peut être globale (sur un SoftwareTemplate,
/// commune à tous les clients) ou spécifique (sur un SoftwareInstance, override
/// ou complément). Si instance a 0 procédures, hérite des procédures du template.
model SoftwareProcedure {
  id                  String                 @id @default(cuid())
  softwareTemplateId  String?                @map("software_template_id")
  softwareInstanceId  String?                @map("software_instance_id")
  title               String
  kind                SoftwareProcedureKind  @default(INSTALL)
  body                String                 @default("") @db.Text
  visibility          ContentVisibility      @default(INTERNAL)
  version             Int                    @default(1)
  createdByUserId     String?                @map("created_by_user_id")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  template SoftwareTemplate? @relation("SoftwareTemplateProcedure", fields: [softwareTemplateId], references: [id], onDelete: Cascade)
  instance SoftwareInstance? @relation("SoftwareInstanceProcedure", fields: [softwareInstanceId], references: [id], onDelete: Cascade)

  @@index([softwareTemplateId])
  @@index([softwareInstanceId])
  @@map("software_procedures")
}

enum ContactSoftwareAccessLevel {
  USER
  ADMIN
  APPROVER
  NONE
}

/// Accès attribué à un contact sur un logiciel client. Historisé via
/// grantedAt/revokedAt plutôt que suppression hard.
model ContactSoftwareAccess {
  id                 String                      @id @default(cuid())
  contactId          String                      @map("contact_id")
  softwareInstanceId String                      @map("software_instance_id")
  accessLevel        ContactSoftwareAccessLevel  @default(USER) @map("access_level")
  grantedAt          DateTime                    @default(now()) @map("granted_at")
  grantedByUserId    String?                     @map("granted_by_user_id")
  revokedAt          DateTime?                   @map("revoked_at")
  note               String?                     @db.Text
  visibility         ContentVisibility           @default(INTERNAL)

  contact  Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  instance SoftwareInstance @relation(fields: [softwareInstanceId], references: [id], onDelete: Cascade)

  @@unique([contactId, softwareInstanceId, accessLevel])
  @@index([contactId])
  @@index([softwareInstanceId])
  @@map("contact_software_accesses")
}

// ============================================================================
// APPROBATIONS — socle générique pour actions sensibles (GPO deploy, etc.)
// ============================================================================

enum ApprovalStatusP {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Demande d'approbation polymorphique. `targetType` + `targetId` identifient
/// l'objet sur lequel porte la demande (ex: targetType="gpo_instance").
model ApprovalRequest {
  id              String          @id @default(cuid())
  organizationId  String?         @map("organization_id")
  targetType      String          @map("target_type")
  targetId        String          @map("target_id")
  action          String          // "deploy", "publish", "grant_access", …
  status          ApprovalStatusP @default(PENDING)
  requestedByUserId String        @map("requested_by_user_id")
  decidedByUserId   String?       @map("decided_by_user_id")
  decidedAt         DateTime?     @map("decided_at")
  justification     String?       @db.Text
  decisionNote      String?       @db.Text @map("decision_note")
  payload           Json?
  createdAt         DateTime      @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy  User          @relation("ApprovalRequester", fields: [requestedByUserId], references: [id])
  decidedBy    User?         @relation("ApprovalDecider", fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([targetType, targetId])
  @@index([requestedByUserId])
  @@map("approval_requests")
}

/// Délégué d'approbation pour une organisation + scope.
model ApprovalDelegate {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  scope          String   @default("all") // "all" | "policies" | "gpo" | "scripts" | "changes"
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation("ApprovalDelegateUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, scope])
  @@index([organizationId])
  @@map("approval_delegates")
}

// ============================================================================
// POLITIQUES — GPO, Scripts, PolicyDocuments (mot de passe, accès, rôles…)
// ============================================================================

enum PolicySubcategory {
  GPO
  SCRIPT
  PWD_AD
  PWD_ENTRA
  PRIVILEGED_ACCESS
  M365_ROLES
  KEEPASS
  BACKUP_REPLICATION
  OTHER
}

enum GpoScope {
  COMPUTER
  USER
  MIXED
}

enum ScriptLanguage {
  POWERSHELL
  BASH
  PYTHON
  BATCH
  OTHER
}

/// Catégorie libre pour les fiches Politiques (séparée des catégories
/// Particularités/Logiciels — sémantiquement distincte).
model PolicyCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  icon        String   @default("🛡️")
  color       String   @default("#EF4444")
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isSystem    Boolean  @default(false) @map("is_system")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  gpoTemplates      GpoTemplate[]
  scriptTemplates   ScriptTemplate[]
  policyDocuments   PolicyDocument[]
  policyDocumentTemplates PolicyDocumentTemplate[]

  @@map("policy_categories")
}

// ---------- GPO ----------

/// Modèle de GPO réutilisable. Nom stocké SANS préfixe (`nameStem`) ; le
/// `computedName` est le préfixe c_/u_/cu_ + stem. `nameOverride` permet
/// d'écraser le nom auto si besoin (cas hérités).
model GpoTemplate {
  id                   String            @id @default(cuid())
  nameStem             String            @map("name_stem")
  nameOverride         String?           @map("name_override")
  scope                GpoScope
  categoryId           String?           @map("category_id")
  description          String?           @db.Text
  body                 String            @default("") @db.Text // procédure HTML
  deploymentProcedure  String?           @db.Text @map("deployment_procedure")
  variables            Json?             // [{ key, label, required, hint, default, scope:"domain"|"client" }]
  dependencies         Json?             // { scripts, scheduledTasks, otherGpos }
  tags                 String[]          @default([])
  requiresCapabilities String[]          @default(["hasAD"]) @map("requires_capabilities")
  visibilityDefault    ContentVisibility @default(INTERNAL) @map("visibility_default")
  schemaVersion        Int               @default(1) @map("schema_version")
  publishedAt          DateTime?         @map("published_at")
  archivedAt           DateTime?         @map("archived_at")
  createdByUserId      String?           @map("created_by_user_id")
  updatedByUserId      String?           @map("updated_by_user_id")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  category  PolicyCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?           @relation("GpoTemplateCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?           @relation("GpoTemplateUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  instances GpoInstance[]

  @@index([categoryId])
  @@index([scope])
  @@index([archivedAt])
  @@map("gpo_templates")
}

enum GpoInstanceStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  DEPLOYED
  ARCHIVED
}

/// Instance d'une GPO appliquée à un client. `computedName` reflète le nom
/// GPO avec préfixe + variables résolues.
model GpoInstance {
  id                    String            @id @default(cuid())
  organizationId        String            @map("organization_id")
  templateId            String?           @map("template_id")
  templateSchemaVersion Int?              @map("template_schema_version")
  nameStem              String            @map("name_stem")
  nameOverride          String?           @map("name_override")
  scope                 GpoScope
  computedName          String            @map("computed_name")
  resolvedVariables     Json?             @map("resolved_variables")
  description           String?           @db.Text
  bodyOverride          String?           @db.Text @map("body_override")
  dependencies          Json?
  status                GpoInstanceStatus @default(DRAFT)
  visibility            ContentVisibility @default(INTERNAL)
  syncState             ContentSyncState  @default(IN_SYNC) @map("sync_state")
  deployedAt            DateTime?         @map("deployed_at")
  lastApprovalId        String?           @map("last_approval_id")
  linkedScriptIds       String[]          @default([]) @map("linked_script_ids")
  linkedAssetIds        String[]          @default([]) @map("linked_asset_ids")
  updatedByUserId       String?           @map("updated_by_user_id")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     GpoTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("GpoInstanceUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([templateId])
  @@index([status])
  @@index([visibility])
  @@map("gpo_instances")
}

/// Import d'un fichier GPO (XML/backup). L'IA analyse pour proposer
/// titre/description/procédure/variables.
model GpoImport {
  id                String   @id @default(cuid())
  organizationId    String?  @map("organization_id")
  uploadedByUserId  String?  @map("uploaded_by_user_id")
  filename          String
  rawContent        String   @db.Text @map("raw_content")
  aiAnalysis        Json?    @map("ai_analysis")
  status            String   @default("PENDING") // PENDING | ANALYZED | APPLIED | REJECTED
  resultingTemplateId String? @map("resulting_template_id")
  resultingInstanceId String? @map("resulting_instance_id")
  createdAt         DateTime @default(now()) @map("created_at")

  uploadedBy User? @relation("GpoImportUploader", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([status])
  @@map("gpo_imports")
}

// ---------- Scripts ----------

model ScriptTemplate {
  id                String            @id @default(cuid())
  title             String
  language          ScriptLanguage
  categoryId        String?           @map("category_id")
  bodyCode          String            @default("") @db.Text @map("body_code")
  bodyDocMarkdown   String?           @db.Text @map("body_doc_markdown")
  variables         Json?
  tags              String[]          @default([])
  runAs             String?           @map("run_as") // "SYSTEM" | "USER" | "CUSTOM:xxx"
  schedule          String?           // cron-like
  visibilityDefault ContentVisibility @default(INTERNAL) @map("visibility_default")
  schemaVersion     Int               @default(1) @map("schema_version")
  publishedAt       DateTime?         @map("published_at")
  archivedAt        DateTime?         @map("archived_at")
  createdByUserId   String?           @map("created_by_user_id")
  updatedByUserId   String?           @map("updated_by_user_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  category     PolicyCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy    User?              @relation("ScriptTemplateCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy    User?              @relation("ScriptTemplateUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  instances    ScriptInstance[]
  publications ScriptPublication[]

  @@index([categoryId])
  @@index([language])
  @@map("script_templates")
}

/// Variante client d'un script (editable indépendamment quand détachée).
model ScriptInstance {
  id                    String            @id @default(cuid())
  organizationId        String            @map("organization_id")
  templateId            String?           @map("template_id")
  templateSchemaVersion Int?              @map("template_schema_version")
  title                 String
  language              ScriptLanguage
  bodyCode              String            @default("") @db.Text @map("body_code")
  bodyDocMarkdown       String?           @db.Text @map("body_doc_markdown")
  resolvedVariables     Json?             @map("resolved_variables")
  runAs                 String?           @map("run_as")
  schedule              String?
  visibility            ContentVisibility @default(INTERNAL)
  syncState             ContentSyncState  @default(IN_SYNC) @map("sync_state")
  status                ContentStatus     @default(ACTIVE)
  updatedByUserId       String?           @map("updated_by_user_id")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     ScriptTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  updatedBy    User?           @relation("ScriptInstanceUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([templateId])
  @@map("script_instances")
}

/// Publication officielle d'un script pour un client — version figée, code
/// rendu avec variables résolues. Utilisée quand l'agent déploie une version
/// précise approuvée.
model ScriptPublication {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  templateId       String   @map("template_id")
  publishedVersion Int      @map("published_version")
  resolvedVariables Json?   @map("resolved_variables")
  renderedCode     String   @db.Text @map("rendered_code")
  approvalId       String?  @map("approval_id")
  publishedAt      DateTime @default(now()) @map("published_at")
  supersededBy     String?  @map("superseded_by")
  status           String   @default("ACTIVE") // ACTIVE | SUPERSEDED | REVOKED
  createdByUserId  String?  @map("created_by_user_id")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     ScriptTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy    User?          @relation("ScriptPublicationCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, templateId])
  @@index([status])
  @@map("script_publications")
}

// ---------- PolicyDocument (PWD_AD, PWD_ENTRA, PRIVILEGED_ACCESS, M365_ROLES, KEEPASS, BACKUP_REPLICATION, OTHER) ----------

model PolicyDocumentTemplate {
  id                   String            @id @default(cuid())
  subcategory          PolicySubcategory
  title                String
  categoryId           String?           @map("category_id")
  summary              String?           @db.Text
  body                 String            @default("") @db.Text
  structuredFields     Json?             @map("structured_fields")
  variables            Json?
  requiresCapabilities String[]          @default([]) @map("requires_capabilities")
  tags                 String[]          @default([])
  visibilityDefault    ContentVisibility @default(INTERNAL) @map("visibility_default")
  schemaVersion        Int               @default(1) @map("schema_version")
  publishedAt          DateTime?         @map("published_at")
  archivedAt           DateTime?         @map("archived_at")
  createdByUserId      String?           @map("created_by_user_id")
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  category  PolicyCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdBy User?             @relation("PolicyDocumentTemplateCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  instances PolicyDocument[]

  @@index([subcategory])
  @@index([categoryId])
  @@map("policy_document_templates")
}

model PolicyDocument {
  id                    String            @id @default(cuid())
  organizationId        String            @map("organization_id")
  templateId            String?           @map("template_id")
  templateSchemaVersion Int?              @map("template_schema_version")
  subcategory           PolicySubcategory
  title                 String
  categoryId            String?           @map("category_id")
  summary               String?           @db.Text
  body                  String            @default("") @db.Text
  structuredFields      Json?             @map("structured_fields")
  resolvedVariables     Json?             @map("resolved_variables")
  tags                  String[]          @default([])
  visibility            ContentVisibility @default(INTERNAL)
  status                ContentStatus     @default(ACTIVE)
  syncState             ContentSyncState  @default(IN_SYNC) @map("sync_state")
  authorId              String?           @map("author_id")
  updatedByUserId       String?           @map("updated_by_user_id")
  lastReviewedAt        DateTime?         @map("last_reviewed_at")
  /// Full-text search — tsvector populé par trigger (config french_unaccent).
  searchVector          Unsupported("tsvector")? @map("search_vector")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     PolicyDocumentTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  category     PolicyCategory?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author       User?                   @relation("PolicyDocumentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  updatedBy    User?                   @relation("PolicyDocumentUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([subcategory])
  @@index([visibility])
  @@index([status])
  @@index([searchVector], type: Gin)
  @@map("policy_documents")
}

// ============================================================================
// CHANGEMENTS — fil chronologique par client, suggestions IA séparées
// ============================================================================

enum ChangeStatus {
  AI_SUGGESTED  // signal IA, pas encore validé
  IN_REVIEW
  APPROVED
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum ChangeCategory {
  INFRASTRUCTURE
  NETWORK_SECURITY
  IDENTITY_ACCESS
  M365_CLOUD
  SOFTWARE
  BACKUPS
  WORKSTATIONS
  TELECOM_PRINT
  CONTRACTS
  ORGANIZATIONAL
  OTHER
}

enum ChangeImpact {
  MINOR
  MODERATE
  MAJOR
  STRUCTURAL
}

model Change {
  id             String            @id @default(cuid())
  organizationId String            @map("organization_id")
  title          String
  summary        String?           @db.Text
  body           String            @default("") @db.Text
  category       ChangeCategory
  status         ChangeStatus      @default(AI_SUGGESTED)
  impact         ChangeImpact      @default(MODERATE)
  visibility     ContentVisibility @default(INTERNAL)
  changeDate     DateTime          @map("change_date")
  detectedAt     DateTime?         @map("detected_at")
  aiConfidence   Float?            @map("ai_confidence")
  /// [{type:"ticket"|"project"|"policy"|"note"|"particularity"|..., id:string, excerpt?:string}]
  sources        Json?
  manualEntry    Boolean           @default(false) @map("manual_entry")
  /// Si true, exposable au portail client (CLIENT_ADMIN) à la publication.
  exposeToClientAdmin Boolean      @default(false) @map("expose_to_client_admin")
  authorId       String?           @map("author_id")
  reviewerId     String?           @map("reviewer_id")
  approverId     String?           @map("approver_id")
  mergedIntoId   String?           @map("merged_into_id")
  linkedTicketIds   String[] @default([]) @map("linked_ticket_ids")
  linkedAssetIds    String[] @default([]) @map("linked_asset_ids")
  linkedSoftwareIds String[] @default([]) @map("linked_software_ids")
  linkedPolicyIds   String[] @default([]) @map("linked_policy_ids")
  linkedParticularityIds String[] @default([]) @map("linked_particularity_ids")
  searchVector   Unsupported("tsvector")? @map("search_vector")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  publishedAt    DateTime?         @map("published_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  author       User?        @relation("ChangeAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  reviewer     User?        @relation("ChangeReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  approver     User?        @relation("ChangeApprover", fields: [approverId], references: [id], onDelete: SetNull)
  mergedInto   Change?      @relation("ChangeMerge", fields: [mergedIntoId], references: [id], onDelete: SetNull)
  mergedFrom   Change[]     @relation("ChangeMerge")
  aiSignals    ChangeAiSignal[] @relation("SignalProposedChange")

  @@index([organizationId, changeDate(sort: Desc)])
  @@index([status])
  @@index([category])
  @@index([impact])
  @@index([visibility])
  @@index([searchVector], type: Gin)
  @@map("changes")
}

// ============================================================================
// ACTIFS — garanties, abonnements, contrats de support
// Additif : étend la fiche actif sans casser l'existant.
// ============================================================================

enum WarrantyCoverageLevel {
  BASIC
  ADVANCED
  NBD
  FOUR_HOUR
  CUSTOM
}

model AssetWarranty {
  id              String                 @id @default(cuid())
  assetId         String                 @map("asset_id")
  organizationId  String                 @map("organization_id")
  vendor          String?
  reference       String?
  startDate       DateTime               @map("start_date")
  endDate         DateTime               @map("end_date")
  coverageLevel   WarrantyCoverageLevel  @default(BASIC) @map("coverage_level")
  notes           String?                @db.Text
  visibility      ContentVisibility      @default(INTERNAL)
  contractId      String?                @map("contract_id")
  createdByUserId String?                @map("created_by_user_id")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contract     Contract?     @relation("AssetWarrantyContract", fields: [contractId], references: [id], onDelete: SetNull)
  createdBy    User?         @relation("AssetWarrantyCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([organizationId, endDate])
  @@map("asset_warranties")
}

enum SubscriptionBillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
  MULTIYEAR
  ONE_TIME
  OTHER
}

model AssetSubscription {
  id              String                    @id @default(cuid())
  assetId         String?                   @map("asset_id")
  softwareInstanceId String?                @map("software_instance_id")
  organizationId  String                    @map("organization_id")
  vendor          String?
  plan            String?
  reference       String?
  startDate       DateTime                  @map("start_date")
  endDate         DateTime                  @map("end_date")
  autoRenew       Boolean                   @default(false) @map("auto_renew")
  billingCycle    SubscriptionBillingCycle  @default(YEARLY) @map("billing_cycle")
  amount          Float?
  currency        String                    @default("CAD")
  renewalNotes    String?                   @db.Text @map("renewal_notes")
  notes           String?                   @db.Text
  visibility      ContentVisibility         @default(INTERNAL)
  contractId      String?                   @map("contract_id")
  createdByUserId String?                   @map("created_by_user_id")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  asset        Asset?       @relation(fields: [assetId], references: [id], onDelete: SetNull)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contract     Contract?    @relation("AssetSubscriptionContract", fields: [contractId], references: [id], onDelete: SetNull)
  createdBy    User?        @relation("AssetSubscriptionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([organizationId, endDate])
  @@index([contractId])
  @@map("asset_subscriptions")
}

enum SupportTierLevel {
  L1
  L2
  L3
  TWENTY_FOUR_SEVEN
  BUSINESS_HOURS
  CUSTOM
}

model AssetSupportContract {
  id              String            @id @default(cuid())
  assetId         String            @map("asset_id")
  organizationId  String            @map("organization_id")
  contractId      String?           @map("contract_id")
  vendor          String?
  tier            SupportTierLevel  @default(L1)
  startDate       DateTime          @map("start_date")
  endDate         DateTime          @map("end_date")
  /// { email, phone, portalUrl, notes }
  contactInfo     Json?             @map("contact_info")
  notes           String?           @db.Text
  visibility      ContentVisibility @default(INTERNAL)
  createdByUserId String?           @map("created_by_user_id")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  asset        Asset         @relation(fields: [assetId], references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contract     Contract?     @relation("AssetSupportContractContract", fields: [contractId], references: [id], onDelete: SetNull)
  createdBy    User?         @relation("AssetSupportContractCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([organizationId, endDate])
  @@map("asset_support_contracts")
}

/// Signal brut détecté par l'IA (une ligne par source). Consolidé ensuite
/// vers un `Change` (status=AI_SUGGESTED) avant publication humaine.
model ChangeAiSignal {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  sourceType     String   @map("source_type") // ticket | project | project_comment | policy | gpo | script | software | asset | particularity | note
  sourceId       String   @map("source_id")
  rawText        String   @db.Text @map("raw_text")
  detectedAt     DateTime @default(now()) @map("detected_at")
  confidence     Float    @default(0)
  proposedChangeId String? @map("proposed_change_id")
  merged         Boolean  @default(false)
  status         String   @default("OPEN") // OPEN | PROMOTED | DISMISSED

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  proposedChange  Change?      @relation("SignalProposedChange", fields: [proposedChangeId], references: [id], onDelete: SetNull)

  @@index([organizationId, detectedAt(sort: Desc)])
  @@index([status])
  @@index([sourceType, sourceId])
  @@map("change_ai_signals")
}

// ============================================================================
// BUDGETS — Budget annuel IT par organisation. Cetix construit, client approuve,
// suivi prévu vs réel tout au long de l'année.
//
// Workflow : DRAFT → PROPOSED → APPROVED → EXECUTING → CLOSED
//            (REJECTED possible à tout moment → retour DRAFT)
//
// Sources automatiques (via src/lib/budgets/ingest.ts) :
//  - AssetSubscription, SoftwareLicense, AssetWarranty, AssetSupportContract
//  - Contract (services récurrents)
//  - Asset en fin de vie (lifecycleEndDate dans l'année fiscale)
//
// Sources manuelles : pentest, consulting, projets ponctuels, contingence.
// ============================================================================

enum BudgetStatus {
  DRAFT         // Cetix construit
  PROPOSED      // envoyé au client pour approbation
  APPROVED      // baseline locked, exécution en cours
  EXECUTING     // actualAmount se remplit au fil de l'année (alias de APPROVED après signature)
  CLOSED        // fin d'année, figé
  REJECTED      // refusé par client, retourne à DRAFT après ajustements
}

enum BudgetCategory {
  SUBSCRIPTIONS       // abonnements logiciels/SaaS
  LICENSES            // licences perpétuelles ou annuelles
  HARDWARE            // nouveau matériel à acheter
  OBSOLESCENCE        // remplacements d'assets en fin de vie
  WARRANTIES          // garanties matériel à renouveler
  SUPPORT             // contrats de support (L1/L2/24x7)
  EXTERNAL_SERVICES   // services ponctuels : pentest, audit SOC2, conseil
  PROJECTS            // projets IT internes
  TRAINING            // formations utilisateurs/admins
  TELECOM             // Internet, téléphonie, forfaits mobiles
  CONTINGENCY         // ligne de contingence (imprévus)
  OTHER
}

enum BudgetLineSource {
  AUTO_SUBSCRIPTION     // AssetSubscription
  AUTO_LICENSE          // SoftwareLicense
  AUTO_WARRANTY         // AssetWarranty
  AUTO_SUPPORT          // AssetSupportContract
  AUTO_CONTRACT         // Contract récurrent
  AUTO_ASSET_EOL        // Asset lifecycleEndDate
  MANUAL                // saisi à la main
}

enum BudgetLineStatus {
  PLANNED     // prévu (ligne issue d'ingest ou saisie)
  COMMITTED   // engagé ferme (PO émise, devis signé)
  INVOICED    // facturé par le fournisseur
  PAID        // payé
  CANCELLED   // annulé (n'entre plus dans le réalisé)
}

model Budget {
  id              String       @id @default(cuid())
  organizationId  String       @map("organization_id")
  /// Année fiscale : année civile du mois de début. Ex: fy=2026 avec
  /// fiscalYearStartMonth=4 → avril 2026 → mars 2027.
  fiscalYear      Int          @map("fiscal_year")
  title           String       // ex: "Budget IT 2026"
  summary         String?      @db.Text
  status          BudgetStatus @default(DRAFT)
  currency        String       @default("CAD")
  /// Montant total cible (ceiling) fixé par Cetix/client. Les lignes doivent
  /// roughly y cadrer. Si null, pas de cible explicite.
  targetAmount    Decimal?     @db.Decimal(14, 2) @map("target_amount")
  /// Ligne de contingence en % (ex: 10 pour 10%). Appliquée au sommant des
  /// lignes PLANNED pour l'affichage du "budget total avec contingence".
  contingencyPct  Float        @default(0) @map("contingency_pct")
  /// Notes Cetix internes, jamais exposées portail même si visibility CLIENT_*.
  internalNotes   String?      @db.Text @map("internal_notes")
  /// Visibilité du budget en entier. Lignes peuvent avoir visibility plus
  /// restrictive (INTERNAL), mais le budget lui-même doit être au moins
  /// CLIENT_ADMIN pour que le client puisse l'approuver.
  visibility      ContentVisibility @default(CLIENT_ADMIN)
  proposedAt      DateTime?    @map("proposed_at")
  approvedAt      DateTime?    @map("approved_at")
  closedAt        DateTime?    @map("closed_at")
  /// Référence à la demande d'approbation (ApprovalRequest) créée à PROPOSED.
  approvalId      String?      @map("approval_id")
  createdByUserId String?      @map("created_by_user_id")
  updatedByUserId String?      @map("updated_by_user_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?            @relation("BudgetCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy    User?            @relation("BudgetUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)
  lines        BudgetLine[]
  versions     BudgetVersion[]
  comments     BudgetComment[]

  @@unique([organizationId, fiscalYear])
  @@index([organizationId])
  @@index([status])
  @@map("budgets")
}

model BudgetLine {
  id              String           @id @default(cuid())
  budgetId        String           @map("budget_id")
  category        BudgetCategory
  source          BudgetLineSource @default(MANUAL)
  /// Type de la ressource source (polymorphe, string-typed). Valeurs :
  /// "asset_subscription" | "software_license" | "asset_warranty" |
  /// "asset_support_contract" | "contract" | "asset" | null pour MANUAL.
  sourceRefType   String?          @map("source_ref_type")
  sourceRefId     String?          @map("source_ref_id")
  label           String
  vendor          String?
  /// Mois de l'année fiscale où la dépense tombe (1-12, relatif à l'année
  /// fiscale du budget). Si null, "flexible / réparti".
  plannedMonth    Int?             @map("planned_month")
  plannedAmount   Decimal          @db.Decimal(14, 2) @map("planned_amount")
  committedAmount Decimal?         @db.Decimal(14, 2) @map("committed_amount")
  actualAmount    Decimal?         @db.Decimal(14, 2) @map("actual_amount")
  currency        String           @default("CAD")
  status          BudgetLineStatus @default(PLANNED)
  /// Hérite la visibility du budget par défaut, mais peut être restreint
  /// à INTERNAL pour cacher une ligne sensible au client même si le budget
  /// est CLIENT_ADMIN.
  visibility      ContentVisibility @default(CLIENT_ADMIN)
  notes           String?          @db.Text
  /// Date d'échéance cible (pour les lignes avec une date précise de
  /// renouvellement/commande). Utile pour alertes 90j.
  dueDate         DateTime?        @map("due_date")
  createdByUserId String?          @map("created_by_user_id")
  updatedByUserId String?          @map("updated_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  budget    Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("BudgetLineCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedBy User?  @relation("BudgetLineUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([budgetId])
  @@index([category])
  @@index([sourceRefType, sourceRefId])
  @@index([dueDate])
  @@map("budget_lines")
}

/// Snapshot immuable à chaque transition de statut. Permet de restaurer
/// une version antérieure ou tracer ce qui a été approuvé par le client.
model BudgetVersion {
  id              String       @id @default(cuid())
  budgetId        String       @map("budget_id")
  version         Int
  statusAtSnapshot BudgetStatus @map("status_at_snapshot")
  /// Payload complet budget + lignes au moment du snapshot.
  snapshot        Json
  note            String?
  authorId        String?      @map("author_id")
  createdAt       DateTime     @default(now()) @map("created_at")

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  author User?  @relation("BudgetVersionAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@unique([budgetId, version])
  @@index([budgetId])
  @@map("budget_versions")
}

/// Commentaires sur un budget (agent ou client via portail). Permet une
/// discussion asynchrone pendant la phase PROPOSED.
model BudgetComment {
  id         String   @id @default(cuid())
  budgetId   String   @map("budget_id")
  /// Optionnel : commentaire attaché à une ligne spécifique plutôt qu'au
  /// budget global.
  lineId     String?  @map("line_id")
  body       String   @db.Text
  /// Source : "agent" (Cetix) ou "portal" (client via portail). Déterminé
  /// au POST selon la session. Permet UI de colorer différemment.
  source     String   @default("agent")
  /// Si source=agent, authorId = User. Si portal, authorPortalUserId set.
  authorId            String?  @map("author_id")
  authorPortalUserId  String?  @map("author_portal_user_id")
  authorName          String?  @map("author_name")
  createdAt  DateTime @default(now()) @map("created_at")

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  author User?  @relation("BudgetCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([budgetId, createdAt(sort: Desc)])
  @@map("budget_comments")
}

// ============================================================================
// BUG REPORTS — Agents signalent des bugs in-app. Après approbation, un worker
// Claude tourne la nuit et propose une PR GitHub. Pas de merge auto, jamais.
//
// Workflow : NEW → TRIAGED → APPROVED_FOR_FIX → FIX_IN_PROGRESS → FIX_PROPOSED
//            → FIXED (PR merged) | REJECTED | DUPLICATE
//
// Auto-fix gated : zones interdites (auth, crypto, migrations, billing
// critique) — si touchées, le worker abandonne et escalade.
// ============================================================================

enum BugSeverity {
  LOW        // cosmétique, texte, styling mineur
  MEDIUM     // fonctionnalité dégradée mais contournable
  HIGH       // fonctionnalité cassée, pas de workaround trivial
  CRITICAL   // perte de données possible, crash, sécurité
}

enum BugStatus {
  NEW                  // nouveau signalement, pas trié
  TRIAGED              // lu et catégorisé, en attente de décision
  APPROVED_FOR_FIX     // approuvé pour auto-fix nocturne
  FIX_IN_PROGRESS      // worker en train d'analyser
  FIX_PROPOSED         // PR ouverte, en attente merge humain
  FIXED                // PR mergée
  REJECTED             // refusé (won't fix / by design)
  DUPLICATE            // doublon d'un autre bug
}

enum BugFixAttemptStatus {
  ANALYZING      // Claude lit le code
  PROPOSED       // patch généré, PR ouverte
  MERGED         // PR mergée → bug fixé
  ABANDONED      // worker a décidé d'abandonner (zone interdite, complexité)
  FAILED         // erreur technique (build/lint/test fail)
  REJECTED       // utilisateur a rejeté le fix proposé
}

model BugReport {
  id                String       @id @default(cuid())
  title             String
  description       String       @db.Text
  stepsToReproduce  String?      @db.Text @map("steps_to_reproduce")
  severity          BugSeverity  @default(MEDIUM)
  status            BugStatus    @default(NEW)
  /// Utilisateur qui a signalé (agent). Pour un bug portail client, on
  /// peut étendre avec reporterPortalUserId + reporterOrgId plus tard.
  reporterUserId    String?      @map("reporter_user_id")
  reporterEmail     String?      @map("reporter_email")
  /// URL de la page où le bug a été constaté. Capturé côté client.
  contextUrl        String?      @map("context_url")
  /// Blob contextuel : navigateur, userAgent, derniers logs console, route
  /// active, etc. Schéma libre côté client.
  contextMeta       Json?        @map("context_meta")
  /// URLs/chemins de screenshots uploadés (via l'endpoint /api/v1/bugs/[id]/attachments).
  screenshots       Json?
  /// Lien ticket si le bug provient d'une investigation de ticket.
  linkedTicketId    String?      @map("linked_ticket_id")
  duplicateOfId     String?      @map("duplicate_of_id")
  /// Assignation manuelle pour un fix humain (bypass worker).
  assignedToUserId  String?      @map("assigned_to_user_id")
  /// Approbation : token signé pour workflow email + traçabilité.
  approvalToken     String?      @unique @map("approval_token")
  approvedForAutoFixAt DateTime? @map("approved_for_auto_fix_at")
  approvedByUserId  String?      @map("approved_by_user_id")
  rejectedAt        DateTime?    @map("rejected_at")
  rejectedByUserId  String?      @map("rejected_by_user_id")
  rejectionReason   String?      @db.Text @map("rejection_reason")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  reporter          User?              @relation("BugReporter", fields: [reporterUserId], references: [id], onDelete: SetNull)
  assignedTo        User?              @relation("BugAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  approvedBy        User?              @relation("BugApprover", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  rejectedBy        User?              @relation("BugRejecter", fields: [rejectedByUserId], references: [id], onDelete: SetNull)
  duplicateOf       BugReport?         @relation("BugDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates        BugReport[]        @relation("BugDuplicates")
  fixAttempts       BugFixAttempt[]
  comments          BugComment[]

  @@index([status])
  @@index([severity])
  @@index([reporterUserId])
  @@index([createdAt(sort: Desc)])
  @@map("bug_reports")
}

model BugFixAttempt {
  id              String              @id @default(cuid())
  bugId           String              @map("bug_id")
  status          BugFixAttemptStatus @default(ANALYZING)
  /// Modèle Anthropic utilisé (claude-sonnet-4-6, claude-opus-4-7, etc.)
  agentModel      String              @map("agent_model")
  /// Branche git créée : bugfix/bug-{shortId}-slug
  branch          String?
  commitSha       String?             @map("commit_sha")
  prUrl           String?             @map("pr_url")
  prNumber        Int?                @map("pr_number")
  /// Résumé généré par Claude du fix proposé (pour email + UI).
  diffSummary     String?             @db.Text @map("diff_summary")
  filesChanged    String[]            @map("files_changed")
  /// Confiance auto-estimée (0-1). Utilisé pour prioriser le review humain.
  confidence      Float?
  testsRun        Boolean             @default(false) @map("tests_run")
  testsPass       Boolean?            @map("tests_pass")
  /// Coût cumulé (USD) pour traçabilité. Pas un cap — on logge seulement.
  tokensInput     Int?                @map("tokens_input")
  tokensOutput    Int?                @map("tokens_output")
  costUsd         Decimal?            @db.Decimal(10, 4) @map("cost_usd")
  abortReason     String?             @db.Text @map("abort_reason")
  logs            String?             @db.Text // stdout/stderr tronqué (50kb max)
  startedAt       DateTime            @default(now()) @map("started_at")
  endedAt         DateTime?           @map("ended_at")

  bug BugReport @relation(fields: [bugId], references: [id], onDelete: Cascade)

  @@index([bugId, startedAt(sort: Desc)])
  @@index([status])
  @@map("bug_fix_attempts")
}

model BugComment {
  id         String   @id @default(cuid())
  bugId      String   @map("bug_id")
  body       String   @db.Text
  authorUserId String? @map("author_user_id")
  authorName String?  @map("author_name")
  createdAt  DateTime @default(now()) @map("created_at")

  bug    BugReport @relation(fields: [bugId], references: [id], onDelete: Cascade)
  author User?     @relation("BugCommentAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([bugId, createdAt(sort: Desc)])
  @@map("bug_comments")
}
