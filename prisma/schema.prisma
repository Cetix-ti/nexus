// Nexus ITSM Platform - Database Schema
// Multi-tenant MSP architecture with organization-level data isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// MULTI-TENANT & ORGANIZATION
// ============================================================================

model Organization {
  id             String    @id @default(cuid())
  externalSource String?   @map("external_source")
  externalId     String?   @unique @map("external_id")
  clientCode     String?   @unique @map("client_code")
  name           String
  slug           String    @unique
  domain         String?
  domains        String[]  @default([])
  website        String?
  description    String?   @db.Text
  phone          String?
  address        String?
  city           String?
  province       String?
  postalCode     String?   @map("postal_code")
  country        String?
  logo           String?
  logoOverridden Boolean   @default(false) @map("logo_overridden")
  lastEnrichedAt DateTime? @map("last_enriched_at")
  primaryColor   String?   @map("primary_color")
  plan           String    @default("standard")
  isActive       Boolean   @default(true) @map("is_active")
  /// Organisation interne (Cetix elle-même). Sert à ancrer les tickets
  /// et projets internes sans polluer les agrégats clients.
  isInternal     Boolean   @default(false) @map("is_internal")

  // Portal config
  // Par défaut : portail ACTIF, les trois méthodes d'auth autorisées
  // (Microsoft, Google, local password) et les contacts sont ajoutés
  // comme utilisateurs STANDARD (peuvent créer et suivre leurs billets).
  // Ces valeurs par défaut s'appliquent aux nouvelles orgs ; les orgs
  // existantes ont été alignées via scripts/portal-defaults-migrate.ts.
  portalEnabled       Boolean    @default(true) @map("portal_enabled")
  portalAuthProviders String[]   @default(["microsoft", "google", "local"]) @map("portal_auth_providers")
  portalDefaultRole   PortalRole @default(STANDARD) @map("portal_default_role")

  /// Alias utilisés dans les titres de calendrier Outlook pour mapper un
  /// événement à ce client. Vient compléter `clientCode` quand les agents
  /// écrivent "VG LV" alors que le code officiel n'est pas "LV". Exemple
  /// pratique : pour "Ville de Louiseville" dont clientCode peut être null
  /// ou "VDL", on ajoute ["LV"] dans calendarAliases. Match insensible à
  /// la casse et aux accents (normalisation côté décodeur).
  calendarAliases String[] @default([]) @map("calendar_aliases")

  /// Patterns de hostname utilisés par le résolveur d'organisation du
  /// Centre de sécurité. Match en SUBSTRING insensible à la casse — utile
  /// quand le nom de poste ne suit pas la convention CODE-XXX. Exemples :
  ///   - Hulix Construction : ["STATION-LAV"] → matche "STATION-LAV-36"
  ///   - École X : ["LAB-INFO", "PORTABLE-PROF"]
  /// Vient compléter `clientCode` (priorité au prefix code, fallback aux
  /// patterns substring si pas de match).
  endpointPatterns String[] @default([]) @map("endpoint_patterns")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sites                 Site[]
  internetLinks         OrgInternetLink[]
  contacts              Contact[]
  users                 UserOrganization[]
  tickets               Ticket[]
  contracts             Contract[]
  assets                Asset[]
  categories            Category[]
  slaPolicies           SLAPolicy[]
  queues                Queue[]
  tags                  Tag[]
  articles              Article[]
  articleCategories     ArticleCategory[]
  automations           AutomationRule[]
  announcements         Announcement[]
  expenseEntries        ExpenseEntry[]
  purchaseOrders        PurchaseOrder[]
  projects              Project[]
  sharedResources       SharedResource[]               @relation("SharedWithOrg")
  calendarEvents        CalendarEvent[]
  backupTicketTemplates BackupTicketTemplate[]
  securityAlerts        SecurityAlert[]
  securityIncidents     SecurityIncident[]
  persistenceWhitelists SecurityPersistenceWhitelist[]
  aiConsent             AiConsent?
  mileageRate           OrgMileageRate?
  billingOverride       ClientBillingOverride?
  workTypes             OrgWorkType[]
  rateTiers             OrgRateTier[]
  userScopes            UserOrganizationScope[]
  scheduledReports      ScheduledReport[]
  addons                OrganizationAddon[]
  publishedDashboards   PublishedDashboard[]
  monthlyReports        MonthlyClientReport[]

  // Socle nouveaux modules (Particularités, Politiques, Logiciels, Changements)
  capabilities          OrgCapabilities?
  particularities       Particularity[]
  softwareInstances     SoftwareInstance[]
  softwareInstallers    SoftwareInstaller[]
  softwareLicenses      SoftwareLicense[]
  softwareDownloadLinks SoftwareDownloadLink[]
  gpoInstances          GpoInstance[]
  scriptInstances       ScriptInstance[]
  scriptPublications    ScriptPublication[]
  policyDocuments       PolicyDocument[]
  approvalRequests      ApprovalRequest[]
  approvalDelegates     ApprovalDelegate[]
  changes               Change[]
  changeAiSignals       ChangeAiSignal[]
  assetWarranties       AssetWarranty[]
  assetSubscriptions    AssetSubscription[]
  assetSupportContracts AssetSupportContract[]
  budgets               Budget[]

  /// Si true, les rapports mensuels générés pour ce client sont
  /// automatiquement publiés au portail dès leur création. Sinon, un
  /// agent doit les publier manuellement. Défaut false (publication
  /// manuelle, sécurité par défaut).
  monthlyReportAutoPublish Boolean @default(false) @map("monthly_report_auto_publish")
  /// Variante de rapport mensuel exposée au portail client.
  /// - BOTH : les deux versions (avec $ et heures-seulement) téléchargeables
  /// - WITH_RATES : seulement la version complète avec montants $
  /// - HOURS_ONLY : seulement la version sans tarifs (durées + libellés)
  /// Côté agent : les deux variantes restent toujours accessibles peu
  /// importe ce paramètre.
  clientPortalReportVariant String @default("BOTH") @map("client_portal_report_variant")
  /// Types de facturation actifs pour ce client : sous-ensemble de
  /// "hour_bank" / "professional_services" / "ftig". Drive l'affichage
  /// des onglets/sections dans la page Facturation. Avant Phase 2D :
  /// localStorage par-navigateur, perdu au reset, non synchro entre
  /// agents.
  billingTypes              String[] @default([]) @map("billing_types")
  /// Modules activés pour ce client (Phase 10F). Sous-ensemble de :
  /// "monitoring", "backups", "security_center", "kb", "assets",
  /// "billing_reports", "tickets". Si vide ou null, on considère
  /// que tous les modules sont actifs (rétrocompat). Drive l'affichage
  /// des sections portail client — un client sans contrat monitoring
  /// ne verra pas la section Veeam/alertes même si la permission est
  /// accordée par défaut sur ses contacts.
  enabledModules            String[] @default([]) @map("enabled_modules")

  @@map("organizations")
}

model Site {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  address        String?
  city           String?
  state          String?
  postalCode     String?  @map("postal_code")
  country        String?
  phone          String?
  isMain         Boolean  @default(false) @map("is_main")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  assets         Asset[]
  tickets        Ticket[]
  calendarEvents CalendarEvent[]
  internetLinks  OrgInternetLink[]
  vlans          SiteVlan[]

  @@map("sites")
}

// ============================================================================
// USERS, ROLES & PERMISSIONS
// ============================================================================

model User {
  id             String   @id @default(cuid())
  externalSource String?  @map("external_source")
  externalId     String?  @unique @map("external_id")
  email          String   @unique
  passwordHash   String?  @map("password_hash")
  firstName      String   @map("first_name")
  lastName       String   @map("last_name")
  avatar         String?
  phone          String?
  role           UserRole @default(TECHNICIAN)
  /// Rôle custom optionnel (clé de CustomRole). Quand présent, les
  /// permissions accordées à ce rôle s'ajoutent à celles du rôle
  /// système (union). La hiérarchie (hasMinimumRole) continue d'utiliser
  /// `role` uniquement — un rôle custom ne peut pas élever le niveau.
  customRoleKey  String?  @map("custom_role_key")
  isActive       Boolean  @default(true) @map("is_active")
  /// Overrides personnels legacy — continuent de fonctionner mais ne
  /// sont plus éditables via l'UI. Les nouveaux accès passent par
  /// Rôles & Permissions (table RolePermission).
  capabilities   String[] @default([])
  locale         String   @default("fr") // fr | en
  preferences    Json?    @db.JsonB

  /// Allocation kilométrique activée pour cet agent. `false` = pas de
  /// remboursement km monétaire (cas : véhicule d'entreprise fourni, OU
  /// agent payé en temps plutôt qu'en argent pour ses déplacements).
  /// L'agent reste responsable de logger les saisies onsite pour que
  /// le CLIENT soit correctement facturé — seul le remboursement
  /// personnel est désactivé.
  mileageAllocationEnabled Boolean @default(true) @map("mileage_allocation_enabled")
  signature      String?  @db.Text
  signatureHtml  String?  @map("signature_html") @db.Text

  // MFA (TOTP)
  mfaEnabled    Boolean   @default(false) @map("mfa_enabled")
  mfaSecret     String?   @map("mfa_secret") // encrypted TOTP secret
  mfaVerifiedAt DateTime? @map("mfa_verified_at") // last successful MFA verification
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  organizations             UserOrganization[]
  assignedTickets           Ticket[]             @relation("AssignedTechnician")
  createdTickets            Ticket[]             @relation("TicketCreator")
  ticketCollaborations      TicketCollaborator[] @relation("TicketCollaborator")
  comments                  Comment[]
  activities                Activity[]
  articles                  Article[]            @relation("ArticleAuthor")
  assetNotes                AssetNote[]
  aiConversations           AiConversation[]
  expenseReports            ExpenseReport[]      @relation("ExpenseReportSubmitter")
  purchaseOrders            PurchaseOrder[]      @relation("PurchaseOrderRequester")
  managedProjects           Project[]            @relation("ProjectManager")
  projectMemberships        ProjectMember[]
  allowances                AgentAllowance[]
  sharedResources           SharedResource[]     @relation("SharedByUser")
  ticketReminders           TicketReminder[]
  notifications             Notification[]
  assignedSecurityIncidents SecurityIncident[]   @relation("SecurityIncidentAssignee")

  // Calendrier + rencontres
  createdCalendars      Calendar[]
  ownedCalendarEvents   CalendarEvent[]      @relation("CalendarEventOwner")
  createdCalendarEvents CalendarEvent[]      @relation("CalendarEventCreator")
  calendarEventAgents   CalendarEventAgent[] @relation("CalendarEventAgentUser")
  createdMeetings       Meeting[]            @relation("MeetingCreator")
  meetingAgendaItems    MeetingAgendaItem[]
  meetingParticipations MeetingParticipant[]

  // Supervision d'agents — un superviseur peut gérer N agents, un agent
  // peut avoir au plus un superviseur (1:N). Menu "Supervision" visible
  // uniquement pour les users qui ont au moins un entry dans supervisedAgents.
  supervisedAgents        AgentSupervision[]    @relation("Supervisor")
  supervisedBy            AgentSupervision[]    @relation("SupervisedAgent")
  billingLocks            BillingPeriodLock[]   @relation("BillingPeriodLockUser")
  /// Restrictions d'accès par org (Phase 9 : scoping technicien).
  organizationScopes      UserOrganizationScope[] @relation("UserOrgScopeUser")
  organizationScopesGranted UserOrganizationScope[] @relation("UserOrgScopeGranter")
  scheduledReportsCreated ScheduledReport[]    @relation("ScheduledReportCreator")
  dashboards              UserDashboard[]      @relation("UserDashboardOwner")
  generatedMonthlyReports MonthlyClientReport[] @relation("MonthlyReportGenerator")

  // Socle nouveaux modules
  orgCapabilitiesUpdated        OrgCapabilities[]        @relation("OrgCapabilitiesUpdater")
  contentRelationsCreated       ContentRelation[]        @relation("ContentRelationCreator")
  particularitiesAuthored       Particularity[]          @relation("ParticularityAuthor")
  particularitiesUpdated        Particularity[]          @relation("ParticularityUpdater")
  particularityTemplatesCreated ParticularityTemplate[]  @relation("ParticularityTemplateCreator")
  particularityTemplatesUpdated ParticularityTemplate[]  @relation("ParticularityTemplateUpdater")
  particularityVersionsAuthored ParticularityVersion[]   @relation("ParticularityVersionAuthor")
  softwareTemplatesCreated      SoftwareTemplate[]       @relation("SoftwareTemplateCreator")
  softwareTemplatesUpdated      SoftwareTemplate[]       @relation("SoftwareTemplateUpdater")
  softwareInstancesUpdated      SoftwareInstance[]       @relation("SoftwareInstanceUpdater")
  softwareInstancesCetixOwner   SoftwareInstance[]       @relation("SoftwareInstanceCetixOwner")
  softwareInstallersUploaded    SoftwareInstaller[]      @relation("SoftwareInstallerUploader")
  softwareDownloadLinksCreated  SoftwareDownloadLink[]   @relation("SoftwareDownloadLinkCreator")
  softwareLicensesCreated       SoftwareLicense[]        @relation("SoftwareLicenseCreator")
  gpoTemplatesCreated           GpoTemplate[]            @relation("GpoTemplateCreator")
  gpoTemplatesUpdated           GpoTemplate[]            @relation("GpoTemplateUpdater")
  gpoInstancesUpdated           GpoInstance[]            @relation("GpoInstanceUpdater")
  gpoImportsUploaded            GpoImport[]              @relation("GpoImportUploader")
  scriptTemplatesCreated        ScriptTemplate[]         @relation("ScriptTemplateCreator")
  scriptTemplatesUpdated        ScriptTemplate[]         @relation("ScriptTemplateUpdater")
  scriptInstancesUpdated        ScriptInstance[]         @relation("ScriptInstanceUpdater")
  scriptPublicationsCreated     ScriptPublication[]      @relation("ScriptPublicationCreator")
  policyDocumentsAuthored       PolicyDocument[]         @relation("PolicyDocumentAuthor")
  policyDocumentsUpdated        PolicyDocument[]         @relation("PolicyDocumentUpdater")
  policyDocumentTemplatesCreated PolicyDocumentTemplate[] @relation("PolicyDocumentTemplateCreator")
  approvalRequestsRequested     ApprovalRequest[]        @relation("ApprovalRequester")
  approvalRequestsDecided       ApprovalRequest[]        @relation("ApprovalDecider")
  approvalDelegateAssignments   ApprovalDelegate[]       @relation("ApprovalDelegateUser")
  changesAuthored               Change[]                 @relation("ChangeAuthor")
  changesReviewed               Change[]                 @relation("ChangeReviewer")
  changesApproved               Change[]                 @relation("ChangeApprover")
  assetWarrantiesCreated        AssetWarranty[]          @relation("AssetWarrantyCreator")
  assetSubscriptionsCreated     AssetSubscription[]      @relation("AssetSubscriptionCreator")
  assetSupportContractsCreated  AssetSupportContract[]   @relation("AssetSupportContractCreator")
  budgetsCreated                Budget[]                 @relation("BudgetCreator")
  budgetsUpdated                Budget[]                 @relation("BudgetUpdater")
  budgetLinesCreated            BudgetLine[]             @relation("BudgetLineCreator")
  budgetLinesUpdated            BudgetLine[]             @relation("BudgetLineUpdater")
  budgetVersionsCreated         BudgetVersion[]          @relation("BudgetVersionAuthor")
  budgetCommentsAuthored        BudgetComment[]          @relation("BudgetCommentAuthor")
  bugsReported                  BugReport[]              @relation("BugReporter")
  bugsAssigned                  BugReport[]              @relation("BugAssignee")
  bugsApproved                  BugReport[]              @relation("BugApprover")
  bugsRejected                  BugReport[]              @relation("BugRejecter")
  bugCommentsAuthored           BugComment[]             @relation("BugCommentAuthor")

  @@map("users")
}

// ============================================================================
// SUPERVISION D'AGENTS
//
// Relation explicite superviseur → agent. Gérée dans Paramètres (super-admin
// uniquement). La page /supervision utilise cette table pour déterminer
// quels agents le user connecté supervise et afficher leurs métriques.
// ============================================================================

model AgentSupervision {
  id           String   @id @default(cuid())
  supervisorId String   @map("supervisor_id")
  agentId      String   @map("agent_id")
  createdAt    DateTime @default(now()) @map("created_at")

  supervisor User @relation("Supervisor", fields: [supervisorId], references: [id], onDelete: Cascade)
  agent      User @relation("SupervisedAgent", fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([supervisorId, agentId])
  @@index([supervisorId])
  @@index([agentId])
  @@map("agent_supervisions")
}

// ============================================================================
// RÔLES & PERMISSIONS
//
// Le système combine des rôles SYSTÈME (enum UserRole, 7 valeurs fixes,
// utilisées par hasMinimumRole pour la hiérarchie) et des rôles CUSTOM
// définis à l'exécution par l'admin via le panneau "Rôles & Permissions".
//
// Les PERMISSIONS sont des chaînes libres (ex. "tickets.view",
// "finances", "billing") stockées dans RolePermission, reliées à une
// clé de rôle (peut être une valeur UserRole en string ou une clé
// CustomRole). hasCapability(user, cap) vérifie :
//   1. user.capabilities (override personnel)
//   2. RolePermission.roleKey = user.role (grant de rôle)
//
// L'enum UserRole reste inchangé pour préserver la logique de hiérarchie
// (hasMinimumRole). Les custom roles n'y participent pas — ils sont
// utilisés comme buckets de permissions assignables en complément.
// ============================================================================

model CustomRole {
  key         String    @id // ex: "comptable_senior"
  label       String // ex: "Comptable senior"
  description String?
  color       String? // hex (#RRGGBB) pour l'icône
  // Rôle système hérité pour la hiérarchie. Si null, le rôle custom
  // n'hérite de rien (permissions uniquement explicites).
  parentRole  UserRole?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@map("custom_roles")
}

model RolePermission {
  id            String   @id @default(cuid())
  // Clé du rôle : valeur UserRole en string ("TECHNICIAN") ou key
  // d'un CustomRole ("comptable_senior"). On ne met PAS de foreign key
  // pour accommoder les deux cas.
  roleKey       String   @map("role_key")
  permissionKey String   @map("permission_key")
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([roleKey, permissionKey])
  @@index([roleKey])
  @@map("role_permissions")
}

// ============================================================================
// DASHBOARDS PUBLIÉS AU PORTAIL CLIENT
//
// Un agent peut publier un de ses dashboards custom (stocké en localStorage
// côté agent) pour qu'un client le voie dans son portail (section Rapports).
// Snapshot FIGÉ : au moment de la publication, on sérialise le layout +
// les widgets concernés dans `config`. Les modifications ultérieures côté
// agent n'affectent pas la version publiée — l'agent doit re-publier pour
// mettre à jour.
//
// Scope : le dashboard est visible aux contacts de l'organisation cible
// (ou "toutes les organisations" si organizationId est null).
// ============================================================================

model PublishedDashboard {
  id             String   @id @default(cuid())
  // Clé locale du dashboard côté agent (ex. "report_kpi_xyz"). Permet
  // à l'UI agent de retrouver "est-ce que ce dashboard est publié ?".
  dashboardKey   String   @map("dashboard_key")
  label          String
  description    String?
  // Organisation autorisée à voir ce dashboard. Null = toutes les orgs
  // du portail (rare ; surtout pour tests / dashboards "tous clients").
  organizationId String?  @map("organization_id")
  // Snapshot complet : { widgets: CustomWidget[], layout: DashboardItem[] }.
  // Le portail lit d'ici et ignore ce qui est en localStorage agent.
  config         Json
  // Audit
  publishedById  String   @map("published_by_id")
  publishedAt    DateTime @default(now()) @map("published_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([dashboardKey])
  @@map("published_dashboards")
}

enum UserRole {
  SUPER_ADMIN
  MSP_ADMIN
  SUPERVISOR
  TECHNICIAN
  CLIENT_ADMIN
  CLIENT_USER
  READ_ONLY
}

model UserOrganization {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           UserRole @default(CLIENT_USER)
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("user_organizations")
}

model Contact {
  id             String  @id @default(cuid())
  externalSource String? @map("external_source")
  externalId     String? @unique @map("external_id")
  organizationId String  @map("organization_id")
  siteId         String? @map("site_id")
  firstName      String  @map("first_name")
  lastName       String  @map("last_name")
  email          String
  phone          String?
  jobTitle       String? @map("job_title")
  isVIP          Boolean @default(false) @map("is_vip")
  isActive       Boolean @default(true) @map("is_active")

  // Portal auth & preferences
  locale            String    @default("fr") // fr | en
  passwordHash      String?   @map("password_hash")
  portalEnabled     Boolean   @default(true) @map("portal_enabled")
  lastPortalLoginAt DateTime? @map("last_portal_login_at")

  // HR status: active, inactive, permanent_departure, partial_departure, temporary_departure
  portalStatus String? @map("portal_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           Site?             @relation(fields: [siteId], references: [id])
  tickets        Ticket[]          @relation("TicketRequester")
  assignedAssets Asset[]           @relation("AssignedContact")
  portalAccess   PortalAccessUser?
  assetNotes     AssetNote[]       @relation("AssetNoteContact")
  // Logiciels
  softwareResponsibleAt SoftwareInstance[]     @relation("SoftwareInstanceClientOwner")
  softwareLicenses      SoftwareLicense[]      @relation("SoftwareLicenseContact")
  softwareAccesses      ContactSoftwareAccess[]

  @@map("contacts")
}

// ============================================================================
// TICKETS
// ============================================================================

model Ticket {
  id             String  @id @default(cuid())
  externalSource String? @map("external_source")
  externalId     String? @unique @map("external_id")
  number         Int     @unique @default(autoincrement())
  organizationId String  @map("organization_id")
  siteId         String? @map("site_id")
  requesterId    String? @map("requester_id")
  assigneeId     String? @map("assignee_id")
  creatorId      String  @map("creator_id")
  categoryId     String? @map("category_id")
  queueId        String? @map("queue_id")
  slaPolicyId    String? @map("sla_policy_id")

  subject         String
  description     String  @db.Text
  descriptionHtml String? @map("description_html") @db.Text

  status             TicketStatus   @default(NEW)
  /// Priorité par défaut = LOW. Le créateur peut surcharger explicitement
  /// (medium, high, critical). L'IA peut ensuite ré-évaluer et remonter
  /// la priorité SI sa confiance est "high" (voir src/lib/ai/auto-prioritize.ts).
  /// `prioritySource` garde une trace de l'origine pour l'UI.
  priority           TicketPriority @default(LOW)
  /// Origine de la valeur courante de `priority` :
  ///   - null ou "DEFAULT" : valeur par défaut (LOW), jamais touchée
  ///   - "MANUAL"          : fixée explicitement par un humain
  ///   - "AI"              : ajustée par l'IA après création
  prioritySource     String?        @map("priority_source")
  /// Origine de la catégorie courante : null/DEFAULT = jamais fixée,
  /// MANUAL = choix explicite humain (ne jamais écraser),
  /// AI = appliquée par le triage automatique avec sa confidence loguée.
  categorySource     String?        @map("category_source")
  /// Confidence (0-1) de l'IA au moment de l'application auto — affichée
  /// dans l'UI à côté de la catégorie.
  categoryConfidence Float?         @map("category_confidence")
  /// Résumé court (1-2 phrases) généré par l'IA pour clarifier le sujet
  /// dans les livrables (ex. rapport mensuel client) quand le titre seul
  /// est insuffisant. Null si pas encore généré ou confidence trop basse.
  aiSummary           String?        @map("ai_summary") @db.Text
  aiSummaryConfidence Float?         @map("ai_summary_confidence")
  aiSummaryGeneratedAt DateTime?     @map("ai_summary_generated_at")
  urgency            TicketUrgency  @default(MEDIUM)
  impact             TicketImpact   @default(MEDIUM)
  type               TicketType     @default(INCIDENT)
  source             TicketSource   @default(PORTAL)

  dueAt           DateTime? @map("due_at")
  firstResponseAt DateTime? @map("first_response_at")
  resolvedAt      DateTime? @map("resolved_at")
  closedAt        DateTime? @map("closed_at")
  slaBreached     Boolean   @default(false) @map("sla_breached")

  isEscalated Boolean @default(false) @map("is_escalated")
  isOverdue   Boolean @default(false) @map("is_overdue")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site         Site?        @relation(fields: [siteId], references: [id])
  requester    Contact?     @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee     User?        @relation("AssignedTechnician", fields: [assigneeId], references: [id])
  creator      User         @relation("TicketCreator", fields: [creatorId], references: [id])
  category     Category?    @relation(fields: [categoryId], references: [id])
  queue        Queue?       @relation(fields: [queueId], references: [id])
  slaPolicy    SLAPolicy?   @relation(fields: [slaPolicyId], references: [id])

  // Monitoring (alertes Zabbix/Atera/etc.)
  monitoringSourceId String?                @map("monitoring_source_id")
  monitoringSource   MonitoringAlertSource? @relation("MonitoringAlertSource", fields: [monitoringSourceId], references: [id])
  monitoringStage    MonitoringAlertStage?  @map("monitoring_stage")
  monitoringNotes    String?                @map("monitoring_notes") @db.Text

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id])

  // Interne (administratif Cetix) vs client. isInternal=true exclut le
  // ticket des vues clients (liste, kanban, my-day) et le fait apparaitre
  // dans /internal-tickets.
  isInternal Boolean  @default(false) @map("is_internal")
  meetingId  String?  @map("meeting_id") // ticket généré par une rencontre
  // onDelete: SetNull → si la rencontre est supprimée, le ticket interne
  // reste mais perd son lien retour (plutôt que de disparaître).
  meeting    Meeting? @relation(fields: [meetingId], references: [id], onDelete: SetNull)

  // Planification sur place — marquer un ticket "à faire sur place" le
  // rend candidat à être lié à un CalendarEvent kind=WORK_LOCATION via
  // calendarEventId. Le lien est filtré par organisation côté UI pour que
  // les suggestions se limitent aux tickets du client visité.
  requiresOnSite  Boolean        @default(false) @map("requires_on_site")
  calendarEventId String?        @map("calendar_event_id")
  calendarEvent   CalendarEvent? @relation("CalendarEventLinkedTickets", fields: [calendarEventId], references: [id], onDelete: SetNull)

  // Approval workflow
  requiresApproval Boolean        @default(false) @map("requires_approval")
  approvalStatus   ApprovalStatus @default(NOT_REQUIRED) @map("approval_status")

  comments             Comment[]
  attachments          Attachment[]
  activities           Activity[]
  ticketTags           TicketTag[]
  relatedAssets        TicketAsset[]
  approvals            TicketApproval[]
  collaborators        TicketCollaborator[]
  reminders            TicketReminder[]
  subtasks             TicketSubtask[]
  // Dépendances sortantes : "ce ticket dépend de" X tickets amont.
  dependencies         TicketDependency[]   @relation("DependentTicket")
  // Dépendances entrantes : X tickets dépendent de celui-ci.
  dependents           TicketDependency[]   @relation("UpstreamTicket")
  // Events calendrier qui pointent vers ce ticket interne (suivi visuel).
  linkedCalendarEvents CalendarEvent[]      @relation("CalendarEventInternalTicket")
  // Incidents de sécurité liés à ce ticket. Un ticket peut regrouper
  // plusieurs incidents (ex: "ticket endpoint" qui agrège tous les CVE /
  // persistence / comportements suspects d'un même poste en une seule
  // intervention facturable).
  securityIncidents    SecurityIncident[]   @relation("SecurityIncidentTicket")

  /// Vecteur d'embedding du ticket (sujet + description) calculé par
  /// nomic-embed-text via Ollama. 768 dimensions, sauvegardé comme Json
  /// pour rester portable (pas besoin de pgvector pour la V1). Permet :
  ///   - similarité sémantique (cosine) vs matching par tokens
  ///   - classement automatique via centroids de catégorie
  ///   - détection de tickets récurrents cross-time
  /// Peuplé en asynchrone via le job `ticket-embeddings` après création.
  embedding      Json?     @map("embedding")
  embeddingAt    DateTime? @map("embedding_at")
  embeddingModel String?   @map("embedding_model")

  @@index([organizationId, status])
  @@index([requiresOnSite, status])
  @@index([calendarEventId])
  @@index([assigneeId])
  @@index([requesterId])
  @@index([createdAt])
  @@index([status, priority])
  @@index([monitoringSourceId, monitoringStage])
  @@map("tickets")
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  ON_SITE
  PENDING
  WAITING_CLIENT
  WAITING_VENDOR
  SCHEDULED
  RESOLVED
  CLOSED
  CANCELLED
  /// Soft-delete : le ticket reste en DB (corbeille) mais est exclu
  /// des vues par défaut. Restorable vers NEW. Recherche par sujet/
  /// numéro continue de le trouver pour permettre la récupération
  /// d'un ticket supprimé par erreur.
  DELETED
}

