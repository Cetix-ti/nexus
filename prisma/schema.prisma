// ============================================================================
// SLA OVERRIDES — per-org SLA profiles overriding the global defaults
// ============================================================================

model OrgSlaOverride {
  id                         String   @id @default(cuid())
  organizationId             String   @unique @map("organization_id")
  // 4 priorities × 2 timings = 8 fields, simpler than a child table
  lowFirstResponseHours      Float    @default(8) @map("low_first_response_hours")
  lowResolutionHours         Float    @default(72) @map("low_resolution_hours")
  mediumFirstResponseHours   Float    @default(4) @map("medium_first_response_hours")
  mediumResolutionHours      Float    @default(24) @map("medium_resolution_hours")
  highFirstResponseHours     Float    @default(1) @map("high_first_response_hours")
  highResolutionHours        Float    @default(8) @map("high_resolution_hours")
  criticalFirstResponseHours Float    @default(0.25) @map("critical_first_response_hours")
  criticalResolutionHours    Float    @default(4) @map("critical_resolution_hours")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@map("org_sla_overrides")
}

// Singleton row for the global SLA defaults
model GlobalSlaProfile {
  id                         String   @id @default("global")
  lowFirstResponseHours      Float    @default(8) @map("low_first_response_hours")
  lowResolutionHours         Float    @default(72) @map("low_resolution_hours")
  mediumFirstResponseHours   Float    @default(4) @map("medium_first_response_hours")
  mediumResolutionHours      Float    @default(24) @map("medium_resolution_hours")
  highFirstResponseHours     Float    @default(1) @map("high_first_response_hours")
  highResolutionHours        Float    @default(8) @map("high_resolution_hours")
  criticalFirstResponseHours Float    @default(0.25) @map("critical_first_response_hours")
  criticalResolutionHours    Float    @default(4) @map("critical_resolution_hours")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@map("global_sla_profile")
}

