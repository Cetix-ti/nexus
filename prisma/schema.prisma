// Nexus ITSM Platform - Database Schema
// Multi-tenant MSP architecture with organization-level data isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// MULTI-TENANT & ORGANIZATION
// ============================================================================

model Organization {
  id          String   @id @default(cuid())
  externalSource String? @map("external_source")
  externalId  String?  @unique @map("external_id")
  clientCode  String?  @unique @map("client_code")
  name        String
  slug        String   @unique
  domain      String?
  domains     String[] @default([])
  website     String?
  description String?  @db.Text
  phone       String?
  address     String?
  city        String?
  province    String?
  postalCode  String?  @map("postal_code")
  country     String?
  logo        String?
  logoOverridden Boolean @default(false) @map("logo_overridden")
  lastEnrichedAt DateTime? @map("last_enriched_at")
  primaryColor String? @map("primary_color")
  plan        String   @default("standard")
  isActive    Boolean  @default(true) @map("is_active")

  // Portal config
  portalEnabled       Boolean  @default(true) @map("portal_enabled")
  portalAuthProviders String[] @default([]) @map("portal_auth_providers")  // ["microsoft", "google", "local"]
  portalDefaultRole   PortalRole? @map("portal_default_role")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  sites       Site[]
  contacts    Contact[]
  users       UserOrganization[]
  tickets     Ticket[]
  contracts   Contract[]
  assets      Asset[]
  categories  Category[]
  slaPolicies SLAPolicy[]
  queues      Queue[]
  tags        Tag[]
  articles    Article[]
  articleCategories ArticleCategory[]
  automations AutomationRule[]
  announcements Announcement[]
  expenseEntries ExpenseEntry[]
  purchaseOrders PurchaseOrder[]
  projects       Project[]
  sharedResources SharedResource[] @relation("SharedWithOrg")

  @@map("organizations")
}

model Site {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  name           String
  address        String?
  city           String?
  state          String?
  postalCode     String?      @map("postal_code")
  country        String?
  phone          String?
  isMain         Boolean      @default(false) @map("is_main")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  assets         Asset[]
  tickets        Ticket[]

  @@map("sites")
}

// ============================================================================
// USERS, ROLES & PERMISSIONS
// ============================================================================

model User {
  id             String    @id @default(cuid())
  externalSource String?   @map("external_source")
  externalId     String?   @unique @map("external_id")
  email          String    @unique
  passwordHash   String?   @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  avatar         String?
  phone          String?
  role           UserRole  @default(TECHNICIAN)
  isActive       Boolean   @default(true) @map("is_active")
  locale         String    @default("fr") // fr | en
  preferences    Json?     @db.JsonB

  // MFA (TOTP)
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret") // encrypted TOTP secret
  mfaVerifiedAt  DateTime? @map("mfa_verified_at") // last successful MFA verification
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organizations  UserOrganization[]
  assignedTickets Ticket[]  @relation("AssignedTechnician")
  createdTickets  Ticket[]  @relation("TicketCreator")
  ticketCollaborations TicketCollaborator[] @relation("TicketCollaborator")
  comments       Comment[]
  activities     Activity[]
  articles       Article[] @relation("ArticleAuthor")
  assetNotes     AssetNote[]
  aiConversations AiConversation[]
  expenseReports  ExpenseReport[] @relation("ExpenseReportSubmitter")
  purchaseOrders  PurchaseOrder[] @relation("PurchaseOrderRequester")
  managedProjects Project[]       @relation("ProjectManager")
  sharedResources SharedResource[] @relation("SharedByUser")
  ticketReminders TicketReminder[]
  notifications   Notification[]

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  MSP_ADMIN
  SUPERVISOR
  TECHNICIAN
  CLIENT_ADMIN
  CLIENT_USER
  READ_ONLY
}

model UserOrganization {
  id             String       @id @default(cuid())
  userId         String       @map("user_id")
  organizationId String       @map("organization_id")
  role           UserRole     @default(CLIENT_USER)
  isDefault      Boolean      @default(false) @map("is_default")
  createdAt      DateTime     @default(now()) @map("created_at")

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("user_organizations")
}

model Contact {
  id             String       @id @default(cuid())
  externalSource String?      @map("external_source")
  externalId     String?      @unique @map("external_id")
  organizationId String       @map("organization_id")
  siteId         String?      @map("site_id")
  firstName      String       @map("first_name")
  lastName       String       @map("last_name")
  email          String
  phone          String?
  jobTitle       String?      @map("job_title")
  isVIP          Boolean      @default(false) @map("is_vip")
  isActive       Boolean      @default(true) @map("is_active")

  // Portal auth & preferences
  locale         String       @default("fr") // fr | en
  passwordHash   String?      @map("password_hash")
  portalEnabled  Boolean      @default(true) @map("portal_enabled")
  lastPortalLoginAt DateTime? @map("last_portal_login_at")

  // HR status: active, inactive, permanent_departure, partial_departure, temporary_departure
  portalStatus   String?      @map("portal_status")

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           Site?        @relation(fields: [siteId], references: [id])
  tickets        Ticket[]     @relation("TicketRequester")
  assignedAssets Asset[]      @relation("AssignedContact")
  portalAccess   PortalAccessUser?
  assetNotes     AssetNote[]  @relation("AssetNoteContact")

  @@map("contacts")
}

// ============================================================================
// TICKETS
// ============================================================================

model Ticket {
  id             String        @id @default(cuid())
  externalSource String?       @map("external_source")
  externalId     String?       @unique @map("external_id")
  number         Int           @unique @default(autoincrement())
  organizationId String        @map("organization_id")
  siteId         String?       @map("site_id")
  requesterId    String?       @map("requester_id")
  assigneeId     String?       @map("assignee_id")
  creatorId      String        @map("creator_id")
  categoryId     String?       @map("category_id")
  queueId        String?       @map("queue_id")
  slaPolicyId    String?       @map("sla_policy_id")

  subject        String
  description    String        @db.Text
  descriptionHtml String?      @map("description_html") @db.Text

  status         TicketStatus  @default(NEW)
  priority       TicketPriority @default(MEDIUM)
  urgency        TicketUrgency @default(MEDIUM)
  impact         TicketImpact  @default(MEDIUM)
  type           TicketType    @default(INCIDENT)
  source         TicketSource  @default(PORTAL)

  dueAt          DateTime?     @map("due_at")
  firstResponseAt DateTime?   @map("first_response_at")
  resolvedAt     DateTime?     @map("resolved_at")
  closedAt       DateTime?     @map("closed_at")
  slaBreached    Boolean       @default(false) @map("sla_breached")

  isEscalated    Boolean       @default(false) @map("is_escalated")
  isOverdue      Boolean       @default(false) @map("is_overdue")

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           Site?         @relation(fields: [siteId], references: [id])
  requester      Contact?      @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee       User?         @relation("AssignedTechnician", fields: [assigneeId], references: [id])
  creator        User          @relation("TicketCreator", fields: [creatorId], references: [id])
  category       Category?     @relation(fields: [categoryId], references: [id])
  queue          Queue?        @relation(fields: [queueId], references: [id])
  slaPolicy      SLAPolicy?   @relation(fields: [slaPolicyId], references: [id])

  // Monitoring (alertes Zabbix/Atera/etc.)
  monitoringSourceId String? @map("monitoring_source_id")
  monitoringSource   MonitoringAlertSource? @relation("MonitoringAlertSource", fields: [monitoringSourceId], references: [id])
  monitoringStage    MonitoringAlertStage? @map("monitoring_stage")
  monitoringNotes    String? @map("monitoring_notes") @db.Text

  projectId      String?       @map("project_id")
  project        Project?      @relation(fields: [projectId], references: [id])

  // Approval workflow
  requiresApproval Boolean       @default(false) @map("requires_approval")
  approvalStatus   ApprovalStatus @default(NOT_REQUIRED) @map("approval_status")

  comments       Comment[]
  attachments    Attachment[]
  activities     Activity[]
  ticketTags     TicketTag[]
  relatedAssets  TicketAsset[]
  approvals      TicketApproval[]
  collaborators  TicketCollaborator[]
  reminders      TicketReminder[]

  @@index([organizationId, status])
  @@index([assigneeId])
  @@index([requesterId])
  @@index([createdAt])
  @@index([status, priority])
  @@index([monitoringSourceId, monitoringStage])
  @@map("tickets")
}

enum TicketStatus {
  NEW
  OPEN
  IN_PROGRESS
  ON_SITE
  PENDING
  WAITING_CLIENT
  WAITING_VENDOR
  SCHEDULED
  RESOLVED
  CLOSED
  CANCELLED
}

enum TicketPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketUrgency {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketImpact {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum TicketType {
  INCIDENT
  SERVICE_REQUEST
  PROBLEM
  CHANGE
  ALERT
}

enum TicketSource {
  PORTAL
  EMAIL
  PHONE
  CHAT
  API
  MONITORING
  AUTOMATION
}

enum ApprovalStatus {
  NOT_REQUIRED
  PENDING
  APPROVED
  REJECTED
}

model TicketCollaborator {
  id          String   @id @default(cuid())
  ticketId    String   @map("ticket_id")
  userId      String   @map("user_id")
  role        String   @default("collaborator") // collaborator | observer
  addedAt     DateTime @default(now()) @map("added_at")

  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user        User     @relation("TicketCollaborator", fields: [userId], references: [id])

  @@unique([ticketId, userId])
  @@index([userId])
  @@map("ticket_collaborators")
}

model TicketApproval {
  id            String          @id @default(cuid())
  ticketId      String          @map("ticket_id")
  approverId    String          @map("approver_id")
  approverName  String          @map("approver_name")
  approverEmail String          @map("approver_email")
  role          String          @default("primary") // primary | secondary
  status        ApprovalStatus  @default(PENDING)
  comment       String?         @db.Text
  decidedAt     DateTime?       @map("decided_at")
  createdAt     DateTime        @default(now()) @map("created_at")

  ticket        Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([approverEmail, status])
  @@map("ticket_approvals")
}

model Comment {
  id         String      @id @default(cuid())
  ticketId   String      @map("ticket_id")
  authorId   String      @map("author_id")
  body       String      @db.Text
  bodyHtml   String?     @map("body_html") @db.Text
  isInternal Boolean     @default(false) @map("is_internal")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  ticket     Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User        @relation(fields: [authorId], references: [id])
  attachments Attachment[]

  @@index([ticketId, createdAt])
  @@map("comments")
}

model Attachment {
  id         String   @id @default(cuid())
  ticketId   String?  @map("ticket_id")
  commentId  String?  @map("comment_id")
  fileName   String   @map("file_name")
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type")
  url        String
  createdAt  DateTime @default(now()) @map("created_at")

  ticket     Ticket?  @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  comment    Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("attachments")
}

model Activity {
  id         String   @id @default(cuid())
  ticketId   String   @map("ticket_id")
  userId     String?  @map("user_id")
  action     String
  field      String?
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([ticketId, createdAt])
  @@map("activities")
}

// ============================================================================
// CATEGORIES, QUEUES & TAGS
// ============================================================================

model Category {
  id             String       @id @default(cuid())
  organizationId String?      @map("organization_id")
  parentId       String?      @map("parent_id")
  name           String
  description    String?
  icon           String?
  sortOrder      Int          @default(0) @map("sort_order")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Category?     @relation("CategoryTree", fields: [parentId], references: [id])
  children       Category[]    @relation("CategoryTree")
  tickets        Ticket[]

  @@map("categories")
}

model Queue {
  id             String       @id @default(cuid())
  externalId     String?      @unique @map("external_id")
  organizationId String?      @map("organization_id")
  name           String
  description    String?
  isDefault      Boolean      @default(false) @map("is_default")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets        Ticket[]

  @@map("queues")
}

model Tag {
  id             String       @id @default(cuid())
  organizationId String?      @map("organization_id")
  name           String
  color          String       @default("#6B7280")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets        TicketTag[]

  @@map("tags")
}

model TicketTag {
  ticketId  String @map("ticket_id")
  tagId     String @map("tag_id")

  ticket    Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag       Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ticketId, tagId])
  @@map("ticket_tags")
}

// ============================================================================
// SLA
// ============================================================================

model SLAPolicy {
  id                String       @id @default(cuid())
  organizationId    String?      @map("organization_id")
  name              String
  description       String?
  priority          TicketPriority
  firstResponseMinutes Int      @map("first_response_minutes")
  resolutionMinutes    Int      @map("resolution_minutes")
  isActive          Boolean      @default(true) @map("is_active")
  createdAt         DateTime     @default(now()) @map("created_at")

  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets           Ticket[]

  @@map("sla_policies")
}

// ============================================================================
// CONTRACTS
// ============================================================================

model Contract {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  name           String
  type           ContractType @default(SUPPORT)
  status         ContractStatus @default(ACTIVE)
  startDate      DateTime     @map("start_date")
  endDate        DateTime?    @map("end_date")
  monthlyHours   Float?       @map("monthly_hours")
  hourlyRate     Float?       @map("hourly_rate")
  notes          String?      @db.Text
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("contracts")
}

enum ContractType {
  SUPPORT
  MANAGED_SERVICES
  PROJECT
  HOURLY
  RETAINER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRING
  EXPIRED
  CANCELLED
}

// ============================================================================
// ASSETS / CMDB
// ============================================================================

model Asset {
  id             String       @id @default(cuid())
  externalSource String?      @map("external_source")
  externalId     String?      @unique @map("external_id")
  organizationId String       @map("organization_id")
  siteId         String?      @map("site_id")
  name           String
  type           AssetType    @default(OTHER)
  status         AssetStatus  @default(ACTIVE)
  manufacturer   String?
  model          String?
  serialNumber   String?      @map("serial_number")
  purchaseDate   DateTime?    @map("purchase_date")
  warrantyExpiry DateTime?    @map("warranty_expiry")
  ipAddress      String?      @map("ip_address")
  macAddress     String?      @map("mac_address")
  notes          String?      @db.Text
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  assignedContactId String?    @map("assigned_contact_id")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  site           Site?        @relation(fields: [siteId], references: [id])
  assignedContact Contact?    @relation("AssignedContact", fields: [assignedContactId], references: [id])
  tickets        TicketAsset[]
  assetNotes     AssetNote[]

  @@index([organizationId, type])
  @@index([assignedContactId])
  @@map("assets")
}

enum AssetType {
  WORKSTATION
  LAPTOP
  SERVER
  NETWORK
  PRINTER
  MOBILE
  MONITOR
  PERIPHERAL
  SOFTWARE
  VIRTUAL_MACHINE
  CLOUD_RESOURCE
  OTHER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
  LOST
  DISPOSED
}

model TicketAsset {
  ticketId String @map("ticket_id")
  assetId  String @map("asset_id")

  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  asset    Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([ticketId, assetId])
  @@map("ticket_assets")
}

// ============================================================================
// KNOWLEDGE BASE
// ============================================================================
// Hierarchical categories (SharePoint-style document library). Each category
// can have a parent to build a folder tree of arbitrary depth.

model ArticleCategory {
  id             String    @id @default(cuid())
  organizationId String?   @map("organization_id")
  parentId       String?   @map("parent_id")
  name           String
  slug           String
  color          String    @default("#3B82F6")
  icon           String    @default("📁")
  description    String?
  sortOrder      Int       @default(0) @map("sort_order")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization   Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         ArticleCategory?  @relation("ArticleCategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       ArticleCategory[] @relation("ArticleCategoryTree")
  articles       Article[]

  @@unique([organizationId, parentId, slug])
  @@index([parentId])
  @@map("article_categories")
}

model Article {
  id             String        @id @default(cuid())
  externalSource String?       @map("external_source")
  externalId     String?       @unique @map("external_id")
  organizationId String?       @map("organization_id")
  categoryId     String?       @map("category_id")
  authorId       String?       @map("author_id")

  title          String
  slug           String
  summary        String        @default("") @db.Text
  body           String        @default("") @db.Text  // TipTap HTML

  status         ArticleStatus @default(DRAFT)
  isPublic       Boolean       @default(true) @map("is_public")
  tags           String[]      @default([])

  viewCount      Int           @default(0) @map("view_count")
  helpfulCount   Int           @default(0) @map("helpful_count")
  notHelpfulCount Int          @default(0) @map("not_helpful_count")

  // Full-text search vector — populated by trigger, enables native PG search
  // Uses french dictionary for proper accent/stemming handling.
  searchVector   Unsupported("tsvector")? @map("search_vector")

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  publishedAt    DateTime?     @map("published_at")

  organization   Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category       ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author         User?            @relation("ArticleAuthor", fields: [authorId], references: [id])

  @@unique([organizationId, slug])
  @@index([status, isPublic])
  @@index([categoryId])
  @@index([searchVector], type: Gin)
  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================================================
// ANNOUNCEMENTS
// ============================================================================

model Announcement {
  id             String       @id @default(cuid())
  organizationId String?      @map("organization_id")
  title          String
  body           String       @db.Text
  type           String       @default("info")
  isActive       Boolean      @default(true) @map("is_active")
  startsAt       DateTime?    @map("starts_at")
  endsAt         DateTime?    @map("ends_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

// ============================================================================
// AUTOMATIONS
// ============================================================================

model AutomationRule {
  id             String       @id @default(cuid())
  organizationId String?      @map("organization_id")
  name           String
  description    String?
  trigger        String
  conditions     Json
  actions        Json
  isActive       Boolean      @default(true) @map("is_active")
  executionCount Int          @default(0) @map("execution_count")
  lastExecutedAt DateTime?    @map("last_executed_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("automation_rules")
}

// ============================================================================
// APPROVERS — ticket approval workflow per organization
// ============================================================================

model OrgApprover {
  id              String        @id @default(cuid())
  organizationId  String        @map("organization_id")
  contactId       String?       @map("contact_id")
  contactName     String        @map("contact_name")
  contactEmail    String        @map("contact_email")
  contactPhone    String?       @map("contact_phone")
  jobTitle        String?       @map("job_title")
  level           Int           @default(1)
  isPrimary       Boolean       @default(false) @map("is_primary")
  scope           ApproverScope @default(ALL_TICKETS)
  scopeMinAmount  Float?        @map("scope_min_amount")
  notifyByEmail   Boolean       @default(true) @map("notify_by_email")
  notifyBySms     Boolean       @default(false) @map("notify_by_sms")
  isActive        Boolean       @default(true) @map("is_active")
  totalApproved   Int           @default(0) @map("total_approved")
  totalRejected   Int           @default(0) @map("total_rejected")
  averageResponseHours Float?   @map("average_response_hours")
  addedBy         String?       @map("added_by")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([organizationId])
  @@map("org_approvers")
}

enum ApproverScope {
