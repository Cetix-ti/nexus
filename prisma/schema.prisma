// Hierarchical categories (SharePoint-style document library). Each category
// can have a parent to build a folder tree of arbitrary depth.

model ArticleCategory {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  parentId       String?  @map("parent_id")
  name           String
  slug           String
  color          String   @default("#3B82F6")
  icon           String   @default("📁")
  description    String?
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       ArticleCategory?  @relation("ArticleCategoryTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     ArticleCategory[] @relation("ArticleCategoryTree")
  articles     Article[]

  @@unique([organizationId, parentId, slug])
  @@index([parentId])
  @@map("article_categories")
}

model Article {
  id             String  @id @default(cuid())
  externalSource String? @map("external_source")
  externalId     String? @unique @map("external_id")
  organizationId String? @map("organization_id")
  categoryId     String? @map("category_id")
  authorId       String? @map("author_id")

  title   String
  slug    String
  summary String @default("") @db.Text
  body    String @default("") @db.Text // TipTap HTML

  status   ArticleStatus @default(DRAFT)
  isPublic Boolean       @default(true) @map("is_public")
  tags     String[]      @default([])

  viewCount       Int @default(0) @map("view_count")
  helpfulCount    Int @default(0) @map("helpful_count")
  notHelpfulCount Int @default(0) @map("not_helpful_count")

  // Full-text search vector — populated by trigger, enables native PG search
  // Uses french dictionary for proper accent/stemming handling.
  searchVector Unsupported("tsvector")? @map("search_vector")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")

  organization Organization?    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author       User?            @relation("ArticleAuthor", fields: [authorId], references: [id])

  @@unique([organizationId, slug])
  @@index([status, isPublic])
  @@index([categoryId])
  @@index([searchVector], type: Gin)
  @@map("articles")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

